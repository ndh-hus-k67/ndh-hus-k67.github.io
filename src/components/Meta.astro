---
import { getImage } from "astro:assets";
import type { ImageMetadata } from "astro";
import { getCollection } from "astro:content";
import {
  LOCAL_BUSINESS_SCHEMA,
  OG,
  ORGANIZATION_SCHEMA,
  PLACE_SCHEMA,
  PRODUCT_OFFER_CATALOG_SCHEMA,
  SEO,
  SITE,
  WEBSITE_SCHEMA,
} from "@data/constants";
import faviconSvgSrc from "@images/icon.svg";
import { generateGraphSchema } from "@/utils/schemas";

// Default properties for the Meta component. These values are used if props are not provided.
// 'meta' sets a default description meta tag to describe the page content.
// 'structuredData' defines default structured data in JSON-LD format to enhance search engine understanding of the page (for SEO purposes).
const defaultProps = {
  meta: SITE.description,
  structuredData: WEBSITE_SCHEMA,
  customDescription: null,
  customOgTitle: null,
  customOgImage: null,
  customOgImageAlt: null,
  ogType: null,
};

// Extract props with default values assigned from defaultProps. Values can be overridden when the component is used.
// For example:
// <MainLayout title="Custom Title" meta="Custom description." />
const {
  meta = defaultProps.meta,
  structuredData = defaultProps.structuredData,
  customDescription = defaultProps.customDescription,
  customOgTitle = defaultProps.customOgTitle,
  customOgImage = defaultProps.customOgImage,
  customOgImageAlt = defaultProps.customOgImageAlt,
  ogType = defaultProps.ogType,
  lang = "vi",
} = Astro.props;

// Use custom description if provided, otherwise use default meta
const description = customDescription || meta;
// Use custom OG title if provided, otherwise use default OG title
const ogTitle = customOgTitle || OG.title;
const ogDescription = customDescription || OG.description;
const ogTypeResolved = ogType || OG.type;

function normalizeMetaText(value: string): string {
  return value.replace(/\s+/g, " ").trim();
}

function clampMetaText(value: string, maxChars: number): string {
  const normalized = normalizeMetaText(value);
  const chars = Array.from(normalized);

  if (chars.length <= maxChars) return normalized;

  const cutoff = Math.max(0, maxChars - 1);
  const sliced = chars.slice(0, cutoff).join("");
  const lastSpace = sliced.lastIndexOf(" ");
  const wordBoundary = lastSpace >= Math.floor(cutoff * 0.6) ? sliced.slice(0, lastSpace) : sliced;

  return `${wordBoundary.trim()}…`;
}

const metaDescriptionContent = clampMetaText(description, 160);
const ogTitleContent = clampMetaText(ogTitle, 60);
const ogDescriptionContent = clampMetaText(ogDescription, 160);

// Define the metadata for your website and individual pages
const author = SITE.author;

function resolveCanonicalPath(pathname: string): string {
  // Astro's 404 route can render as /404/ while static output is /404.html.
  // Normalize to the actual public file URL to avoid canonical mismatch.
  if (pathname === "/404/" || pathname === "/404") return "/404.html";
  return pathname;
}

const canonical = new URL(
  resolveCanonicalPath(Astro.url.pathname),
  Astro.site || Astro.url.origin
).href;
type ResolvedSocialImage = {
  url: string;
  type?: string;
  width?: number;
  height?: number;
};

let socialImage: ResolvedSocialImage = { url: "" };

function mimeTypeFromUrl(url: string): string | undefined {
  const lower = url.toLowerCase();
  const pathname = lower.split("?")[0].split("#")[0];

  if (pathname.endsWith(".png")) return "image/png";
  if (pathname.endsWith(".jpg") || pathname.endsWith(".jpeg")) return "image/jpeg";
  if (pathname.endsWith(".webp")) return "image/webp";
  if (pathname.endsWith(".avif")) return "image/avif";
  return undefined;
}

function mimeTypeFromFormat(format?: string): string | undefined {
  if (!format) return undefined;
  const f = format.toLowerCase();
  if (f === "png") return "image/png";
  if (f === "jpg" || f === "jpeg") return "image/jpeg";
  if (f === "webp") return "image/webp";
  if (f === "avif") return "image/avif";
  if (f === "gif") return "image/gif";
  if (f === "svg") return "image/svg+xml";
  return undefined;
}

function isImageMetadata(value: unknown): value is ImageMetadata {
  return (
    !!value &&
    typeof value === "object" &&
    "src" in value &&
    "width" in value &&
    "height" in value
  );
}

async function resolveSocialImage(src: any): Promise<ResolvedSocialImage> {
  if (!src) return { url: "" };

  if (typeof src === "string") {
    const url = src.startsWith("http")
      ? src
      : new URL(src, Astro.site || Astro.url.origin).href;

    // When the OG image is configured as a string URL/path (e.g. "/social.jpg"),
    // we can't reliably infer the intrinsic dimensions at build-time.
    // Default to the common social preview size to ensure og:image:width/height
    // are always present for platforms that require them.
    return {
      url,
      type: mimeTypeFromUrl(url),
      width: 1200,
      height: 630,
    };
  }

  if (isImageMetadata(src)) {
    const url = new URL(src.src, Astro.site || Astro.url.origin).href;
    return {
      url,
      type: mimeTypeFromFormat(src.format) ?? mimeTypeFromUrl(url),
      width: src.width,
      height: src.height,
    };
  }

  const res = await getImage({
    src,
    width: 1200,
    height: 630,
    format: "png",
  });

  return {
    url: new URL(res.src, Astro.site || Astro.url.origin).href,
    type: "image/png",
    width: 1200,
    height: 630,
  };
}

socialImage = await resolveSocialImage(customOgImage || OG.image);
const currentLang = lang === "en" ? "en" : "vi";
const ogLocale = currentLang === "en" ? "en_US" : "vi_VN";
const ogImageAlt = customOgImageAlt || ogTitle;

const ogLocaleAlternates = ogLocale === "en_US" ? ["vi_VN"] : ["en_US"];

const localizedSlugMap = {
  en: {
    "lien-he": "contact",
    "ve-chung-toi": "about-us",
    "bai-viet": "blog",
    "bu-long": "bolts",
    "oc-vit": "screws",
    "tan-tu-giu": "self-clinching-nuts",
    "tan-tru-tu-giu": "self-clinching-standoffs",
    "tru-ren-tu-giu": "self-clinching-studs",
    "sen-xich": "chains",
    "phu-kien-nhom-dinh-hinh": "aluminum-profile-accessories",
    "ban-le": "hinges",
    "khoa-gai": "toggle-latches",
  },
  vi: {
    "contact": "lien-he",
    "about-us": "ve-chung-toi",
    "blog": "bai-viet",
    "bolts": "bu-long",
    "screws": "oc-vit",
    "self-clinching-nuts": "tan-tu-giu",
    "self-clinching-standoffs": "tan-tru-tu-giu",
    "self-clinching-studs": "tru-ren-tu-giu",
    "chains": "sen-xich",
    "aluminum-profile-accessories": "phu-kien-nhom-dinh-hinh",
    "hinges": "ban-le",
    "toggle-latches": "khoa-gai",
  },
} as const;

type LanguageKey = "en" | "vi";

type LocalizedPathPair = Partial<Record<LanguageKey, string>>;

function normalizePathname(pathname: string): string {
  if (!pathname) return "/";
  const normalized = pathname.replace(/\/+/g, "/");
  if (normalized.length > 1 && normalized.endsWith("/")) return normalized.slice(0, -1);
  return normalized;
}

function getLangFromContentId(id: string): LanguageKey | null {
  if (id.startsWith("en/")) return "en";
  if (id.startsWith("vn/")) return "vi";
  return null;
}

function entrySlug(entry: any): string {
  return entry?.data?.slug || entry?.id?.split("/").pop() || "";
}

function entryCategorySlug(entry: any): string {
  const category = entry?.data?.category;
  return typeof category === "string" ? category : category?.slug;
}

function buildProductPath(lang: LanguageKey, categorySlug: string, productSlug: string): string {
  const categorySegment = lang === "en"
    ? localizedSlugMap.en[categorySlug as keyof typeof localizedSlugMap.en] ?? categorySlug
    : categorySlug;
  const prefix = lang === "en" ? "/en" : "";
  return normalizePathname(`${prefix}/${categorySegment}/${productSlug}`);
}

function buildBlogPath(lang: LanguageKey, idWithoutLang: string): string {
  const prefix = lang === "en" ? "/en/blog" : "/bai-viet";
  return normalizePathname(`${prefix}/${idWithoutLang}`);
}

function buildStaticPathMap(): Record<string, LocalizedPathPair> {
  const result: Record<string, LocalizedPathPair> = {
    [normalizePathname("/")]: {
      vi: normalizePathname("/"),
      en: normalizePathname("/en"),
    },
  };

  for (const [viSegment, enSegment] of Object.entries(localizedSlugMap.en)) {
    const viPath = normalizePathname(`/${viSegment}`);
    const enPath = normalizePathname(`/en/${enSegment}`);
    result[viPath] = { vi: viPath, en: enPath };
    result[enPath] = { vi: viPath, en: enPath };
  }

  return result;
}

async function buildProductPathMap(): Promise<Record<string, LocalizedPathPair>> {
  const result: Record<string, LocalizedPathPair> = {};

  try {
    const entries = await getCollection("products");
    const byKey = new Map<string, Partial<Record<LanguageKey, { category: string; slug: string }>>>();

    for (const entry of entries as any[]) {
      const lang = getLangFromContentId(entry.id);
      if (!lang) continue;

      const key = entry.id.replace(/^(en|vn)\//, "");
      const category = entryCategorySlug(entry);
      const slug = entrySlug(entry);
      if (!key || !category || !slug) continue;

      const pair = byKey.get(key) ?? {};
      pair[lang] = { category, slug };
      byKey.set(key, pair);
    }

    for (const pair of byKey.values()) {
      const en = pair.en;
      const vi = pair.vi;
      if (!en || !vi) continue;

      const enPath = buildProductPath("en", en.category, en.slug);
      const viPath = buildProductPath("vi", vi.category, vi.slug);

      result[enPath] = { en: enPath, vi: viPath };
      result[viPath] = { en: enPath, vi: viPath };
    }
  } catch {
    return result;
  }

  return result;
}

async function buildBlogPathMap(): Promise<Record<string, LocalizedPathPair>> {
  const result: Record<string, LocalizedPathPair> = {};

  try {
    const entries = await getCollection("blog");
    const byCardImage = new Map<string, Partial<Record<LanguageKey, { idWithoutLang: string }>>>();

    for (const entry of entries as any[]) {
      const lang = getLangFromContentId(entry.id);
      if (!lang) continue;

      const idWithoutLang = entry.id.replace(/^(en|vn)\//, "");
      if (!idWithoutLang) continue;

      const cardImageSrc = String(entry?.data?.cardImage?.src ?? entry?.data?.cardImage ?? "");
      if (!cardImageSrc) continue;

      const pair = byCardImage.get(cardImageSrc) ?? {};
      if (pair[lang]) continue;
      pair[lang] = { idWithoutLang };
      byCardImage.set(cardImageSrc, pair);
    }

    for (const pair of byCardImage.values()) {
      const en = pair.en;
      const vi = pair.vi;
      if (!en || !vi) continue;

      const enPath = buildBlogPath("en", en.idWithoutLang);
      const viPath = buildBlogPath("vi", vi.idWithoutLang);

      result[enPath] = { en: enPath, vi: viPath };
      result[viPath] = { en: enPath, vi: viPath };
    }
  } catch {
    return result;
  }

  return result;
}

function translatePath(clean: string, targetLang: "vi" | "en"): string {
  const parts = clean.split("/").filter(Boolean);
  if (parts.length === 0) return clean;

  const first = parts[0];
  const mapped = localizedSlugMap[targetLang][first as keyof (typeof localizedSlugMap)[typeof targetLang]];
  if (!mapped) return clean;

  return `/${[mapped, ...parts.slice(1)].join("/")}`;
}

function createHref(prefix: string, path: string): string {
  const normalizedPath = path === "/" ? "/" : path.replace(/\/$/, "");
  const localizedPath = prefix
    ? normalizedPath === "/"
      ? `/${prefix}/`
      : `/${prefix}${normalizedPath}/`
    : normalizedPath === "/"
      ? "/"
      : `${normalizedPath}/`;

  return new URL(localizedPath, Astro.site || Astro.url.origin).href;
}

const [productPathMap, blogPathMap] = await Promise.all([
  buildProductPathMap(),
  buildBlogPathMap(),
]);

const staticPathMap = buildStaticPathMap();
const normalizedCurrentPath = normalizePathname(Astro.url.pathname);
const pairedPath =
  productPathMap[normalizedCurrentPath] ||
  blogPathMap[normalizedCurrentPath] ||
  staticPathMap[normalizedCurrentPath];

const resolvedAlternates = pairedPath
  ? {
      vi: pairedPath.vi,
      en: pairedPath.en,
    }
  : (() => {
      const cleanPath = normalizedCurrentPath.replace(/^\/en(?=\/|$)/, "") || "/";
      const translatedViPath = translatePath(cleanPath, "vi");
      const translatedEnPath = translatePath(cleanPath, "en");
      const viPath = createHref("", translatedViPath);
      const enPath = createHref("en", translatedEnPath);
      const isEnglishPage = normalizedCurrentPath.startsWith("/en/") || normalizedCurrentPath === "/en";

      // For unknown dynamic routes, avoid generating speculative cross-language links.
      if (cleanPath.split("/").filter(Boolean).length > 1) {
        return {
          vi: isEnglishPage ? undefined : createHref("", translatedViPath),
          en: isEnglishPage ? createHref("en", translatedEnPath) : undefined,
        };
      }

      return {
        vi: viPath,
        en: enPath,
      };
    })();

const alternateEntries: Array<{ hreflang: string; href: string }> = [];

if (resolvedAlternates.vi) {
  const href = resolvedAlternates.vi.startsWith("http")
    ? resolvedAlternates.vi
    : createHref("", resolvedAlternates.vi);
  alternateEntries.push({ hreflang: "vi-VN", href });
}

if (resolvedAlternates.en) {
  const href = resolvedAlternates.en.startsWith("http")
    ? resolvedAlternates.en
    : createHref("en", resolvedAlternates.en);
  alternateEntries.push({ hreflang: "en", href });
}

if (resolvedAlternates.vi && resolvedAlternates.en) {
  const href = resolvedAlternates.vi.startsWith("http")
    ? resolvedAlternates.vi
    : createHref("", resolvedAlternates.vi);
  alternateEntries.push({ hreflang: "x-default", href });
}

const alternateLanguageLinks: string = alternateEntries
  .map(({ hreflang, href }) =>
    `<link rel="alternate" hreflang="${hreflang}" href="${href}" />`
  )
  .join("\n");

// Generate and optimize the favicon images
const faviconSvg = await getImage({
  src: faviconSvgSrc,
  format: "svg",
});

const appleTouchIcon = await getImage({
  src: faviconSvgSrc,
  width: 180,
  height: 180,
  format: "png",
});

function stripContext(node: any) {
  if (!node || typeof node !== "object") return node;

  // eslint-disable-next-line @typescript-eslint/no-unused-vars
  const { ["@context"]: _context, ...rest } = node as any;
  return rest;
}

function extractGraphNodes(data: any): any[] {
  if (!data) return [];

  if (typeof data === "object" && "@graph" in data && Array.isArray((data as any)["@graph"])) {
    return (data as any)["@graph"].filter(Boolean).map(stripContext);
  }

  return [stripContext(data)];
}

function nodeKey(node: any): string {
  if (!node || typeof node !== "object") return String(node);
  if (typeof node["@id"] === "string" && node["@id"].trim()) return `@id:${node["@id"]}`;
  if (typeof node.url === "string" && node.url.trim()) return `url:${node["@type"] || ""}:${node.url}`;
  if (typeof node.name === "string" && node.name.trim()) return `name:${node["@type"] || ""}:${node.name}`;
  return `json:${JSON.stringify(node)}`;
}

const baselineNodes = [
  WEBSITE_SCHEMA,
  ORGANIZATION_SCHEMA,
  LOCAL_BUSINESS_SCHEMA,
  PLACE_SCHEMA,
  PRODUCT_OFFER_CATALOG_SCHEMA,
].map(stripContext);

const pageNodes = extractGraphNodes(structuredData);
const merged = new Map<string, any>();
for (const node of baselineNodes) merged.set(nodeKey(node), node);
for (const node of pageNodes) merged.set(nodeKey(node), node);

const finalStructuredData = generateGraphSchema(Array.from(merged.values()));
---

{/*  Inject structured data into the page if provided. This data is formatted as JSON-LD, a method recommended by Google for structured data pass:
     https://developers.google.com/search/docs/advanced/structured-data/intro-structured-data */}{
  finalStructuredData && (
    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify(finalStructuredData)}
    />
  )
}
{/* Google Analytics 4 */}
<link rel="preconnect" href="https://www.googletagmanager.com" crossorigin />
<link rel="preconnect" href="https://www.google-analytics.com" crossorigin />
<link rel="dns-prefetch" href="//www.googletagmanager.com" />
<link rel="dns-prefetch" href="//www.google-analytics.com" />
<script is:inline type="module">
  const GA_ID = "G-2KG357SQ8D";

  const loadGtag = () =>
    new Promise((resolve) => {
      const src = `https://www.googletagmanager.com/gtag/js?id=${GA_ID}`;
      const existing = document.querySelector(`script[src="${src}"]`);
      if (existing) return resolve(null);

      const s = document.createElement("script");
      s.async = true;
      s.src = src;
      s.onload = () => resolve(null);
      document.head.appendChild(s);
    });

  const initGA = async () => {
    await loadGtag();
    window.dataLayer = window.dataLayer || [];
    const dataLayer = window.dataLayer;
    function gtag() {
      // eslint-disable-next-line prefer-rest-params
      dataLayer.push(arguments);
    }
    gtag("js", new Date());
    gtag("config", GA_ID);
  };

  if ("requestIdleCallback" in window) {
    // @ts-expect-error - requestIdleCallback may not be in TypeScript lib.dom typings here
    requestIdleCallback(initGA, { timeout: 2000 });
  } else {
    window.addEventListener("load", initGA, { once: true });
  }
</script>
{/* Define the character set, description, author, and viewport settings */}
<meta charset="utf-8" />
<meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
<meta name="googlebot" content="index, follow" />
<meta content={metaDescriptionContent} name="description" />
<meta name="keywords" content={SEO.keywords} />
<meta name="author" content={author} />
<meta name="web_author" content={author} />
<meta name="p:domain_verify" content="3b45234f65a8c8df8dba719213240717" />
<meta
  name="viewport"
  content="width=device-width, initial-scale=1.0, maximum-scale=5.0, minimum-scale=1.0"
/>
<meta http-equiv="X-UA-Compatible" content="ie=edge" />
<link rel="canonical" href={canonical} />
<Fragment set:html={alternateLanguageLinks} />

{/* Facebook Meta Tags */}
<meta property="og:locale" content={ogLocale} />
{ogLocaleAlternates.map((locale) => (
  <meta property="og:locale:alternate" content={locale} />
))}
<meta property="og:url" content={canonical} />
<meta property="og:type" content={ogTypeResolved} />
<meta property="og:title" content={ogTitleContent} />
<meta property="og:site_name" content={SITE.title} />
<meta property="og:description" content={ogDescriptionContent} />
{socialImage.url && <meta property="og:image" content={socialImage.url} />}
{socialImage.url && (
  <meta property="og:image:secure_url" content={socialImage.url} />
)}
{socialImage.url && <meta property="og:image:alt" content={ogImageAlt} />}
{socialImage.width && (
  <meta property="og:image:width" content={String(socialImage.width)} />
)}
{socialImage.height && (
  <meta property="og:image:height" content={String(socialImage.height)} />
)}
{socialImage.type && (
  <meta property="og:image:type" content={socialImage.type} />
)}

{/* Links to the webmanifest and sitemap */}
<link rel="manifest" href="/manifest.json" />
{/* https://docs.astro.build/en/guides/integrations-guide/sitemap/ */}
<link rel="sitemap" href="/sitemap-groups.xml" />

{/* Links for favicons */}
<link href="/favicon.ico" rel="icon" sizes="any" type="image/x-icon" />
<link href={faviconSvg.src} rel="icon" type="image/svg+xml" sizes="any" />
<meta name="mobile-web-app-capable" content="yes" />
<link href={appleTouchIcon.src} rel="apple-touch-icon" />
<link href={appleTouchIcon.src} rel="shortcut icon" />
{/* Set theme color */}
<meta name="theme-color" content="#facc15" />
