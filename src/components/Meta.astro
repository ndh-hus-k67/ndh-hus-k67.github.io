---
import { getImage } from "astro:assets";
import type { ImageMetadata } from "astro";
import { OG, SEO, SITE, WEBSITE_SCHEMA } from "@data/constants";
import faviconSvgSrc from "@images/icon.svg";

// Default properties for the Meta component. These values are used if props are not provided.
// 'meta' sets a default description meta tag to describe the page content.
// 'structuredData' defines default structured data in JSON-LD format to enhance search engine understanding of the page (for SEO purposes).
const defaultProps = {
  meta: SITE.description,
  structuredData: WEBSITE_SCHEMA,
  customDescription: null,
  customOgTitle: null,
  customOgImage: null,
  customOgImageAlt: null,
  ogType: null,
};

// Extract props with default values assigned from defaultProps. Values can be overridden when the component is used.
// For example:
// <MainLayout title="Custom Title" meta="Custom description." />
const {
  meta = defaultProps.meta,
  structuredData = defaultProps.structuredData,
  customDescription = defaultProps.customDescription,
  customOgTitle = defaultProps.customOgTitle,
  customOgImage = defaultProps.customOgImage,
  customOgImageAlt = defaultProps.customOgImageAlt,
  ogType = defaultProps.ogType,
  lang = "vi",
} = Astro.props;

// Use custom description if provided, otherwise use default meta
const description = customDescription || meta;
// Use custom OG title if provided, otherwise use default OG title
const ogTitle = customOgTitle || OG.title;
const ogDescription = customDescription || OG.description;
const ogTypeResolved = ogType || OG.type;

function normalizeMetaText(value: string): string {
  return value.replace(/\s+/g, " ").trim();
}

function clampMetaText(value: string, maxChars: number): string {
  const normalized = normalizeMetaText(value);
  const chars = Array.from(normalized);

  if (chars.length <= maxChars) return normalized;

  const cutoff = Math.max(0, maxChars - 1);
  const sliced = chars.slice(0, cutoff).join("");
  const lastSpace = sliced.lastIndexOf(" ");
  const wordBoundary = lastSpace >= Math.floor(cutoff * 0.6) ? sliced.slice(0, lastSpace) : sliced;

  return `${wordBoundary.trim()}…`;
}

const metaDescriptionContent = clampMetaText(description, 160);
const ogTitleContent = clampMetaText(ogTitle, 60);
const ogDescriptionContent = clampMetaText(ogDescription, 160);

// Define the metadata for your website and individual pages
const author = SITE.author;
const canonical = new URL(
  Astro.url.pathname,
  Astro.site || Astro.url.origin
).href;
type ResolvedSocialImage = {
  url: string;
  type?: string;
  width?: number;
  height?: number;
};

let socialImage: ResolvedSocialImage = { url: "" };

function mimeTypeFromUrl(url: string): string | undefined {
  const lower = url.toLowerCase();
  const pathname = lower.split("?")[0].split("#")[0];

  if (pathname.endsWith(".png")) return "image/png";
  if (pathname.endsWith(".jpg") || pathname.endsWith(".jpeg")) return "image/jpeg";
  if (pathname.endsWith(".webp")) return "image/webp";
  if (pathname.endsWith(".avif")) return "image/avif";
  return undefined;
}

function mimeTypeFromFormat(format?: string): string | undefined {
  if (!format) return undefined;
  const f = format.toLowerCase();
  if (f === "png") return "image/png";
  if (f === "jpg" || f === "jpeg") return "image/jpeg";
  if (f === "webp") return "image/webp";
  if (f === "avif") return "image/avif";
  if (f === "gif") return "image/gif";
  if (f === "svg") return "image/svg+xml";
  return undefined;
}

function isImageMetadata(value: unknown): value is ImageMetadata {
  return (
    !!value &&
    typeof value === "object" &&
    "src" in value &&
    "width" in value &&
    "height" in value
  );
}

async function resolveSocialImage(src: any): Promise<ResolvedSocialImage> {
  if (!src) return { url: "" };

  if (typeof src === "string") {
    const url = src.startsWith("http")
      ? src
      : new URL(src, Astro.site || Astro.url.origin).href;

    // When the OG image is configured as a string URL/path (e.g. "/social.jpg"),
    // we can't reliably infer the intrinsic dimensions at build-time.
    // Default to the common social preview size to ensure og:image:width/height
    // are always present for platforms that require them.
    return {
      url,
      type: mimeTypeFromUrl(url),
      width: 1200,
      height: 630,
    };
  }

  if (isImageMetadata(src)) {
    const url = new URL(src.src, Astro.site || Astro.url.origin).href;
    return {
      url,
      type: mimeTypeFromFormat(src.format) ?? mimeTypeFromUrl(url),
      width: src.width,
      height: src.height,
    };
  }

  const res = await getImage({
    src,
    width: 1200,
    height: 630,
    format: "png",
  });

  return {
    url: new URL(res.src, Astro.site || Astro.url.origin).href,
    type: "image/png",
    width: 1200,
    height: 630,
  };
}

socialImage = await resolveSocialImage(customOgImage || OG.image);
const currentLang = lang === "en" ? "en" : "vi";
const ogLocale = currentLang === "en" ? "en_US" : "vi_VN";
const ogImageAlt = customOgImageAlt || ogTitle;

const ogLocaleAlternates = ogLocale === "en_US" ? ["vi_VN"] : ["en_US"];

const languages = {
  vi: "",
  en: "en",
} as const;

const localizedSlugMap = {
  en: {
    "lien-he": "contact",
    "ve-chung-toi": "about-us",
    "bai-viet": "blog",
    "bu-long": "bolts",
    "oc-vit": "screws",
    "tan-tu-giu": "self-clinching-nuts",
    "tan-tru-tu-giu": "self-clinching-standoffs",
    "tru-ren-tu-giu": "self-clinching-studs",
    "sen-xich": "chains",
    "phu-kien-nhom-dinh-hinh": "aluminum-profile-accessories",
  },
  vi: {
    contact: "lien-he",
    "about-us": "ve-chung-toi",
    blog: "bai-viet",
    bolts: "bu-long",
    screws: "oc-vit",
    "self-clinching-nuts": "tan-tu-giu",
    "self-clinching-standoffs": "tan-tru-tu-giu",
    "self-clinching-studs": "tru-ren-tu-giu",
    chains: "sen-xich",
    "aluminum-profile-accessories": "phu-kien-nhom-dinh-hinh",
  },
} as const;

const cleanPath = Astro.url.pathname.replace(/^\/en(?=\/|$)/, "") || "/";
const englishPendingPrefixes: string[] = [];
const skipEnglishAlternate = englishPendingPrefixes.some(
  (prefix) => cleanPath === prefix || cleanPath.startsWith(`${prefix}/`)
);

function translatePath(clean: string, targetLang: "vi" | "en"): string {
  const parts = clean.split("/").filter(Boolean);
  if (parts.length === 0) return clean;

  const first = parts[0];
  const mapped = localizedSlugMap[targetLang][first as keyof (typeof localizedSlugMap)[typeof targetLang]];
  if (!mapped) return clean;

  return `/${[mapped, ...parts.slice(1)].join("/")}`;
}

function createHref(prefix: string, path: string): string {
  const normalizedPath = path === "/" ? "/" : path.replace(/\/$/, "");
  const localizedPath = prefix
    ? normalizedPath === "/"
      ? `/${prefix}/`
      : `/${prefix}${normalizedPath}/`
    : normalizedPath === "/"
      ? "/"
      : `${normalizedPath}/`;

  return new URL(localizedPath, Astro.site || Astro.url.origin).href;
}

const alternateLanguageLinks: string = Object.entries(languages)
  .filter(([language]) => !(language === "en" && skipEnglishAlternate))
  .map(([language, prefix]) => {
    const targetLang = language === "en" ? "en" : "vi";
    const translatedPath = translatePath(cleanPath, targetLang);
    const href = createHref(prefix, translatedPath);

    return `<link rel="alternate" hreflang="${language}" href="${href}" />`;
  })
  .join("\n");

// Generate and optimize the favicon images
const faviconSvg = await getImage({
  src: faviconSvgSrc,
  format: "svg",
});

const appleTouchIcon = await getImage({
  src: faviconSvgSrc,
  width: 180,
  height: 180,
  format: "png",
});
---

{/*  Inject structured data into the page if provided. This data is formatted as JSON-LD, a method recommended by Google for structured data pass:
     https://developers.google.com/search/docs/advanced/structured-data/intro-structured-data */}{
  structuredData && (
    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify(structuredData)}
    />
  )
}
{/* Google Analytics 4 */}
<script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-2KG357SQ8D"></script>
<script is:inline>
  window.dataLayer = window.dataLayer || [];
  // eslint-disable-next-line prefer-rest-params
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());
  gtag('config', 'G-2KG357SQ8D');
</script>
{/* Define the character set, description, author, and viewport settings */}
<meta charset="utf-8" />
<meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
<meta name="googlebot" content="index, follow" />
<meta content={metaDescriptionContent} name="description" />
<meta name="keywords" content={SEO.keywords} />
<meta name="author" content={author} />
<meta name="web_author" content={author} />
<meta
  name="viewport"
  content="width=device-width, initial-scale=1.0, maximum-scale=5.0, minimum-scale=1.0"
/>
<meta http-equiv="X-UA-Compatible" content="ie=edge" />
<link rel="canonical" href={canonical} />
<Fragment set:html={alternateLanguageLinks} />

{/* Facebook Meta Tags */}
<meta property="og:locale" content={ogLocale} />
{ogLocaleAlternates.map((locale) => (
  <meta property="og:locale:alternate" content={locale} />
))}
<meta property="og:url" content={canonical} />
<meta property="og:type" content={ogTypeResolved} />
<meta property="og:title" content={ogTitleContent} />
<meta property="og:site_name" content={SITE.title} />
<meta property="og:description" content={ogDescriptionContent} />
{socialImage.url && <meta property="og:image" content={socialImage.url} />}
{socialImage.url && (
  <meta property="og:image:secure_url" content={socialImage.url} />
)}
{socialImage.url && <meta property="og:image:alt" content={ogImageAlt} />}
{socialImage.width && (
  <meta property="og:image:width" content={String(socialImage.width)} />
)}
{socialImage.height && (
  <meta property="og:image:height" content={String(socialImage.height)} />
)}
{socialImage.type && (
  <meta property="og:image:type" content={socialImage.type} />
)}

{/* Links to the webmanifest and sitemap */}
<link rel="manifest" href="/manifest.json" />
{/* https://docs.astro.build/en/guides/integrations-guide/sitemap/ */}
<link rel="sitemap" href="/sitemap-index.xml" />

{/* Links for favicons */}
<link href="/favicon.ico" rel="icon" sizes="any" type="image/x-icon" />
<link href={faviconSvg.src} rel="icon" type="image/svg+xml" sizes="any" />
<meta name="mobile-web-app-capable" content="yes" />
<link href={appleTouchIcon.src} rel="apple-touch-icon" />
<link href={appleTouchIcon.src} rel="shortcut icon" />
{/* Set theme color */}
<meta name="theme-color" content="#facc15" />
