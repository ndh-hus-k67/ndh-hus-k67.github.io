---
import { languages } from "@utils//ui";
import Icon from "./icons/Icon.astro";
import { getCollection } from "astro:content";

type TLanguage = "en" | "vn";

const localizedCategorySlugMap: Record<TLanguage, Record<string, string>> = {
  en: {
    "lien-he": "contact",
    "ve-chung-toi": "about-us",
    "bai-viet": "blog",
    "bu-long": "bolts",
    "oc-vit": "screws",
    "tan-tu-giu": "self-clinching-nuts",
    "tan-tru-tu-giu": "self-clinching-standoffs",
    "tru-ren-tu-giu": "self-clinching-studs",
    "sen-xich": "chains",
    "phu-kien-nhom-dinh-hinh": "aluminum-profile-accessories",
    "ban-le": "hinges",
    "khoa-gai": "toggle-latches",
  },
  vn: {
    "contact": "lien-he",
    "about-us": "ve-chung-toi",
    "blog": "bai-viet",
    "bolts": "bu-long",
    "screws": "oc-vit",
    "self-clinching-nuts": "tan-tu-giu",
    "self-clinching-standoffs": "tan-tru-tu-giu",
    "self-clinching-studs": "tru-ren-tu-giu",
    "chains": "sen-xich",
    "aluminum-profile-accessories": "phu-kien-nhom-dinh-hinh",
    "hinges": "ban-le",
    "toggle-latches": "khoa-gai",

  },
};

function getLangFromContentId(id: string): TLanguage | null {
  if (id.startsWith("en/")) return "en";
  if (id.startsWith("vn/")) return "vn";
  return null;
}

function entrySlug(entry: any): string {
  return entry?.data?.slug || entry?.id?.split("/").pop() || "";
}

function entryCategorySlug(entry: any): string {
  const c = entry?.data?.category;
  return typeof c === "string" ? c : c?.slug;
}

function buildProductPath(lang: TLanguage, categorySlug: string, productSlug: string): string {
  const prefix = lang === "en" ? "/en" : "";
  const categorySegment = lang === "en" ? (localizedCategorySlugMap.en[categorySlug] ?? categorySlug) : categorySlug;
  const path = `${prefix}/${categorySegment}/${productSlug}`.replace(/\/+/g, "/");
  return path === "" ? "/" : path;
}

function buildBlogPath(lang: TLanguage, idWithoutLang: string): string {
  const prefix = lang === "en" ? "/en/blog" : "/bai-viet";
  const path = `${prefix}/${idWithoutLang}`.replace(/\/+/g, "/");
  return path === "" ? "/" : path;
}

// Exact path translation (product/blog detail pages) can be very large.
// To protect INP, only generate and inject these maps when we're on a detail page.
const pathname = Astro.url?.pathname ?? "/";
const parts = pathname.split("/").filter(Boolean);

const VN_CATEGORIES = [
  "bu-long",
  "oc-vit",
  "tan-tu-giu",
  "tan-tru-tu-giu",
  "tru-ren-tu-giu",
  "sen-xich",
  "phu-kien-nhom-dinh-hinh",
  "ban-le",
  "khoa-gai",
] as const;

const EN_CATEGORIES = [
  "bolts",
  "screws",
  "self-clinching-nuts",
  "self-clinching-standoffs",
  "self-clinching-studs",
  "chains",
  "aluminum-profile-accessories",
  "hinges",
  "toggle-latches"
] as const;

const isVnProductDetail = parts.length >= 2 && (VN_CATEGORIES as readonly string[]).includes(parts[0]);
const isVnBlogDetail = parts.length >= 2 && parts[0] === "bai-viet";
const isEnProductDetail =
  parts.length >= 3 && parts[0] === "en" && (EN_CATEGORIES as readonly string[]).includes(parts[1]);
const isEnBlogDetail = parts.length >= 3 && parts[0] === "en" && parts[1] === "blog";

const needsExactMaps = isVnProductDetail || isVnBlogDetail || isEnProductDetail || isEnBlogDetail;

const pickerId = `lang-${Math.random().toString(36).slice(2, 9)}`;
const desktopMenuId = `${pickerId}-desktop-menu`;

// Build a URL translation map for product detail pages.
// Keyed by the *actual* route paths (e.g. /en/bolts/t-bolt <-> /bu-long/bu-long-chu-t)
let productPathMap: Record<string, Partial<Record<TLanguage, string>>> = {};
if (needsExactMaps) {
  try {
    const entries = await getCollection("products");
    const byKey = new Map<string, Partial<Record<TLanguage, { category: string; slug: string }>>>();

    for (const entry of entries as any[]) {
      const lang = getLangFromContentId(entry.id);
      if (!lang) continue;

      const key = entry.id.replace(/^(en|vn)\//, "");
      const category = entryCategorySlug(entry);
      const slug = entrySlug(entry);
      if (!category || !slug) continue;

      const prev = byKey.get(key) ?? {};
      (prev as any)[lang] = { category, slug };
      byKey.set(key, prev);
    }

    for (const pair of byKey.values()) {
      const en = (pair as any).en as { category: string; slug: string } | undefined;
      const vn = (pair as any).vn as { category: string; slug: string } | undefined;
      if (!en || !vn) continue;

      const enPath = buildProductPath("en", en.category, en.slug);
      const vnPath = buildProductPath("vn", vn.category, vn.slug);

      productPathMap[enPath] = { en: enPath, vn: vnPath };
      productPathMap[vnPath] = { en: enPath, vn: vnPath };
    }
  } catch {
    // If content is unavailable (shouldn't happen in Astro build), fall back to segment translation.
    productPathMap = {};
  }
}

// Build a URL translation map for blog detail pages.
// Because EN/VN blog slugs may differ, we pair translations via shared cardImage.
// Keyed by the *actual* route paths (e.g. /en/blog/foo <-> /bai-viet/bar)
let blogPathMap: Record<string, Partial<Record<TLanguage, string>>> = {};
if (needsExactMaps) {
  try {
    const entries = await getCollection("blog");
    const byCardImage = new Map<string, Partial<Record<TLanguage, { idWithoutLang: string }>>>();

    for (const entry of entries as any[]) {
      const lang = getLangFromContentId(entry.id);
      if (!lang) continue;

      const idWithoutLang = entry.id.replace(/^(en|vn)\//, "");
      if (!idWithoutLang) continue;

      const cardImageSrc = String(entry?.data?.cardImage?.src ?? entry?.data?.cardImage ?? "");
      if (!cardImageSrc) continue;

      const prev = byCardImage.get(cardImageSrc) ?? {};
      if ((prev as any)[lang]) continue;
      (prev as any)[lang] = { idWithoutLang };
      byCardImage.set(cardImageSrc, prev);
    }

    for (const pair of byCardImage.values()) {
      const en = (pair as any).en as { idWithoutLang: string } | undefined;
      const vn = (pair as any).vn as { idWithoutLang: string } | undefined;
      if (!en || !vn) continue;

      const enPath = buildBlogPath("en", en.idWithoutLang);
      const vnPath = buildBlogPath("vn", vn.idWithoutLang);

      blogPathMap[enPath] = { en: enPath, vn: vnPath };
      blogPathMap[vnPath] = { en: enPath, vn: vnPath };
    }
  } catch {
    // Fall back to segment translation if anything goes wrong.
    blogPathMap = {};
  }
}
---

<!-- Desktop dropdown (independent of Preline; fixes flaky first-interaction when Preline is lazy-loaded) -->
<div class="relative hidden md:inline-flex" data-language-picker>
  <button
    type="button"
    data-lang-desktop-toggle
    aria-controls={desktopMenuId}
    aria-expanded="false"
    aria-label="Change language"
    title="Change language"
    class="inline-flex items-center gap-x-2 rounded-lg px-2 py-2 text-sm font-medium text-neutral-600 outline-hidden ring-zinc-500 transition duration-300 hover:bg-neutral-200 hover:text-orange-400 dark:border-neutral-700 dark:text-neutral-400 dark:ring-zinc-200 dark:hover:bg-neutral-700 dark:hover:text-orange-300 dark:focus:outline-hidden"
  >
    <Icon name="earth" />
    <svg
      data-lang-desktop-arrow
      class="size-4 transition-transform"
      width="24"
      height="24"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"><path d="m6 9 6 6 6-6"></path></svg
    >
  </button>

  <div
    id={desktopMenuId}
    data-lang-desktop-menu
    class="absolute right-0 top-full z-50 mt-2 hidden min-w-28 rounded-lg border border-neutral-200 bg-white p-1 opacity-0 shadow-sm transition-[opacity,margin] dark:border-neutral-700 dark:bg-neutral-800"
  >
    {
      Object.entries(languages).map(([lang, label]) => (
        <a
          class="flex items-center gap-x-3.5 rounded-md px-3 py-2 text-sm text-neutral-800 hover:bg-neutral-100 focus:bg-neutral-100 focus:outline-hidden dark:text-neutral-200 dark:hover:bg-neutral-700 dark:hover:text-neutral-100 dark:focus:bg-neutral-700"
          data-lang-link
          data-lang={lang}
          href={`/${lang === "vn" ? "" : lang}`}
        >
          {label}
        </a>
      ))
    }
  </div>
</div>

<!-- Mobile: accordion (same style as products dropdown) -->
<div class="md:hidden" data-language-picker>
  <button
    type="button"
    data-lang-mobile-toggle
    class="flex items-center gap-x-1 font-medium text-neutral-600 outline-none transition duration-300 hover:text-orange-400 dark:text-neutral-400 dark:hover:text-orange-300"
  >
    <Icon name="earth" />
    <svg
      data-lang-mobile-arrow
      class="h-4 w-4 shrink-0 transition-transform duration-200"
      xmlns="http://www.w3.org/2000/svg"
      width="24"
      height="24"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <path d="m6 9 6 6 6-6"></path>
    </svg>
  </button>

  <ul data-lang-mobile-list class="hidden mt-1 flex-col gap-y-0 border-l-2 border-yellow-300/60 pl-3 dark:border-neutral-600">
    {
      Object.entries(languages).map(([lang, label]) => (
        <li>
          <a
            href={`/${lang === "vn" ? "" : lang}`}
            data-lang-link
            data-lang={lang}
            class="block py-2 text-sm text-neutral-600 hover:text-orange-400 dark:text-neutral-400 dark:hover:text-orange-300"
          >
            {label}
          </a>
        </li>
      ))
    }
  </ul>
</div>

<script
  is:inline
  type="application/json"
  data-lang-picker-maps
  set:html={JSON.stringify({ productPathMap, blogPathMap })}
/>

<script>
  import { initLanguagePickersFromDom } from "@scripts/languagePicker";
  initLanguagePickersFromDom();
</script>
