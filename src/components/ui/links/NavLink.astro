---
// Destructure the properties from Astro.props
const { url, name } = Astro.props;

const normalizePathname = (value: string): string => {
  const normalized = value.replace(/\/+$/, "");
  return normalized === "" ? "/" : normalized;
};

const currentPathname = normalizePathname(Astro.url.pathname);
const targetPathname = normalizePathname(url);
const isActive = currentPathname === targetPathname;

// Define TypeScript interface for the properties
interface Props {
  url: string;
  name: string;
}
---

<!--
Re-usable link component for navigation bar. Highlights the active link
by comparing the current URL with the href of each link.
We assign an ID matching the URL for easy reference in our script.
If URL is '/' (home page), assign ID as 'home' 
-->
<a
  id={url === "/" ? "home" : url.replace("/", "")}
  href={url}
  data-astro-prefetch
  aria-current={isActive ? "page" : undefined}
  class:list={[
    "rounded-lg text-base font-medium outline-hidden ring-zinc-500 focus-visible:ring-3 dark:ring-zinc-200 dark:focus:outline-hidden md:py-3 md:text-sm 2xl:text-base",
    isActive
      ? "text-orange-400 dark:text-orange-300"
      : "text-neutral-600 hover:text-neutral-500 dark:text-neutral-400 dark:hover:text-neutral-500",
  ]}
>
  {name}
</a>
