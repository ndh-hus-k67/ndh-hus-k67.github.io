---
// Import necessary components, modules and types
import MainLayout from "@/layouts/MainLayout.astro";
import CardBlog from "@components/ui/cards/CardBlog.astro";
import CardBlogRecent from "@components/ui/cards/CardBlogRecent.astro";
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
import { SITE } from "@data/constants";
import { generateBreadcrumbSchema, generateGraphSchema } from "@/utils/schemas";

// Get all blogs post in Vietnamese and sort them based on publish date

const PAGE_SIZE = 9;

const vietnameseBlogEntries = await getCollection("blog", ({ id }) => {
  return id.startsWith("vn/");
});

const blogPosts: CollectionEntry<"blog">[] = vietnameseBlogEntries.sort(
  (a: CollectionEntry<"blog">, b: CollectionEntry<"blog">) =>
    b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

// Separate the most recent post from others
const mostRecentPost: CollectionEntry<"blog"> | null = blogPosts[0] ?? null;
const postsWithoutRecent: CollectionEntry<"blog">[] = mostRecentPost
  ? blogPosts.slice(1)
  : blogPosts;
const initialPosts: CollectionEntry<"blog">[] = postsWithoutRecent.slice(0, PAGE_SIZE);
const hasMore: boolean = postsWithoutRecent.length > PAGE_SIZE;

// Define variables for page content
const title: string = "Bài viết phụ kiện nhôm định hình: trượt bi, trượt lẫy & ứng dụng";
const subTitle: string =
  "Tổng hợp kiến thức kỹ thuật về phụ kiện nhôm định hình công nghiệp: cách chọn trượt bi, trượt lẫy, ke chim chong xoay, phụ kiện liên kết profile và kinh nghiệm lắp ráp tối ưu.";
const pageTitle: string = `Bài viết phụ kiện nhôm định hình | ${SITE.title}`;
const metaDescription =
  "Kiến thức phụ kiện nhôm định hình: trượt bi, trượt lẫy, phụ kiện liên kết profile, tiêu chí lựa chọn vật liệu và hướng dẫn lắp ráp bền chắc, tối ưu chi phí.";
const ogTitle = `Bài viết phụ kiện nhôm định hình công nghiệp | ${SITE.title}`;

const blogIndexUrl = new URL("/bai-viet/", SITE.url).href;
const itemListId = `${blogIndexUrl}#itemlist`;

const displayedPosts: CollectionEntry<"blog">[] = mostRecentPost
  ? [mostRecentPost, ...initialPosts]
  : initialPosts;

const collectionPageNode = {
  "@type": "CollectionPage",
  "@id": blogIndexUrl,
  url: blogIndexUrl,
  name: pageTitle,
  description: metaDescription,
  isPartOf: {
    "@id": `${SITE.url}/#website`,
  },
  inLanguage: "vi-VN",
  mainEntity: {
    "@id": itemListId,
  },
};

const itemListNode = {
  "@type": "ItemList",
  "@id": itemListId,
  itemListOrder: "https://schema.org/ItemListOrderDescending",
  numberOfItems: displayedPosts.length,
  itemListElement: displayedPosts.map((entry, index) => {
    const slug = entry.id.replace(/^vn\//, "");
    const url = new URL(`/bai-viet/${slug}/`, SITE.url).href;
    const imageUrl = `${SITE.url}${entry.data.cardImage.src}`;

    return {
      "@type": "ListItem",
      position: index + 1,
      url,
      item: {
        "@type": "BlogPosting",
        "@id": url,
        url,
        headline: entry.data.title,
        name: entry.data.title,
        description: entry.data.description,
        image: [imageUrl],
        datePublished: entry.data.pubDate.toISOString(),
        dateModified: entry.data.pubDate.toISOString(),
        author: {
          "@type": "Organization",
          "@id": `${SITE.url}/#organization`,
          name: SITE.author,
          url: SITE.url,
        },
        publisher: {
          "@id": `${SITE.url}/#organization`,
        },
        keywords: entry.data.tags?.join(", ") || undefined,
        mainEntityOfPage: {
          "@type": "WebPage",
          "@id": url,
        },
        inLanguage: "vi-VN",
      },
    };
  }),
};

const breadcrumbSchemaWithContext = generateBreadcrumbSchema([
  { position: 1, name: "Trang chủ", item: SITE.url },
  { position: 2, name: "Bài viết", item: blogIndexUrl },
]);
// Breadcrumb helper includes @context; strip it to embed into @graph
// eslint-disable-next-line @typescript-eslint/no-unused-vars
const { ["@context"]: _breadcrumbContext, ...breadcrumbNode } =
  breadcrumbSchemaWithContext as any;

const blogIndexStructuredData = generateGraphSchema([
  collectionPageNode,
  itemListNode,
  breadcrumbNode,
]);
---

<MainLayout
  title={pageTitle}
  customDescription={metaDescription}
  customOgTitle={ogTitle}
  structuredData={blogIndexStructuredData}
>
  <section
    class="mx-auto max-w-6xl space-y-4 px-4 pt-10 sm:px-6 lg:px-8"
  >
    <!--Page header-->
    <div class="max-w-3xl">
      <h1
        class="block text-3xl font-semibold tracking-tight text-balance text-neutral-900 md:text-4xl dark:text-neutral-100"
      >
        {title}
      </h1>

      <p
        class="mt-3 text-base leading-relaxed text-pretty text-neutral-600 md:text-lg dark:text-neutral-400"
      >
        {subTitle}
      </p>
    </div>

    <div class="border-b border-neutral-300/70 pt-4 dark:border-neutral-700"></div>
  </section>

  {/* Most recent blog post */}
  {mostRecentPost && (
    <section
      class="mx-auto max-w-6xl px-4 py-8 sm:px-6 lg:px-8"
    >
      <CardBlogRecent blogEntry={mostRecentPost} recentBlogLocale="vn" />

      <div class="mt-8 border-b border-neutral-300/70 dark:border-neutral-700"></div>
    </section>
  )}

  <section
    class="mx-auto max-w-6xl px-4 py-8 sm:px-6 lg:px-8"
  >
    {/* Blog posts grid */}
    <div id="blog-grid" class="grid gap-5 md:grid-cols-2 xl:grid-cols-3">
      {
        postsWithoutRecent.map((blogEntry, index) => (
          <div data-post-card class:list={[index >= PAGE_SIZE ? "hidden" : ""]}>
            <CardBlog blogEntry={blogEntry} blogLocale="vn" />
          </div>
        ))
      }
    </div>

    {hasMore && (
      <div class="mt-10 flex items-center justify-center">
        <button
          id="load-more"
          type="button"
          data-page-size={String(PAGE_SIZE)}
          class="inline-flex items-center justify-center rounded-lg border border-neutral-300 bg-white px-4 py-2.5 text-sm font-semibold text-neutral-800 outline-hidden ring-zinc-500 transition hover:bg-neutral-50 focus-visible:ring-3 dark:border-neutral-700 dark:bg-neutral-900 dark:text-neutral-100 dark:ring-zinc-200 dark:hover:bg-neutral-800"
        >
          Tải thêm bài viết
        </button>
      </div>
    )}
  </section>

  <script is:inline>
    (() => {
      const button = document.getElementById("load-more");
      if (!(button instanceof HTMLButtonElement)) return;

      const pageSize = Number.parseInt(button.dataset.pageSize || "10", 10) || 10;
      const cards = Array.from(document.querySelectorAll("[data-post-card]"));

      const revealMore = () => {
        const hidden = cards.filter((el) => el.classList.contains("hidden"));
        hidden.slice(0, pageSize).forEach((el) => el.classList.remove("hidden"));
        if (cards.every((el) => !el.classList.contains("hidden"))) {
          button.remove();
        }
      };

      button.addEventListener("click", revealMore);
    })();
  </script>
</MainLayout>
