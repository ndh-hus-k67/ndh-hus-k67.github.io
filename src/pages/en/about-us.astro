            Consulting & Quotation
          </h3>
          <p class="text-sm leading-relaxed text-neutral-600 dark:text-neutral-400">
            Experts provide optimal solutions and detailed quotation within 2h
          </p>
        </div>

        <div class="flex flex-col items-center text-center">
          <div class="mb-4 flex h-20 w-20 items-center justify-center rounded-full bg-gradient-to-br from-orange-400 to-orange-600 shadow-lg dark:from-orange-500 dark:to-orange-700">
            <span class="text-3xl font-bold text-white">3</span>
          </div>
          <h3 class="mb-2 text-lg font-bold text-neutral-800 dark:text-neutral-200">
            Order Confirmation
          </h3>
          <p class="text-sm leading-relaxed text-neutral-600 dark:text-neutral-400">
            Sign contract/order and payment as agreed
          </p>
        </div>

        <div class="flex flex-col items-center text-center">
          <div class="mb-4 flex h-20 w-20 items-center justify-center rounded-full bg-gradient-to-br from-orange-400 to-orange-600 shadow-lg dark:from-orange-500 dark:to-orange-700">
            <span class="text-3xl font-bold text-white">4</span>
          </div>
          <h3 class="mb-2 text-lg font-bold text-neutral-800 dark:text-neutral-200">
            Production/Warehouse
          </h3>
          <p class="text-sm leading-relaxed text-neutral-600 dark:text-neutral-400">
            Strict quality inspection before packaging
          </p>
        </div>

        <div class="flex flex-col items-center text-center">
          <div class="mb-4 flex h-20 w-20 items-center justify-center rounded-full bg-gradient-to-br from-orange-400 to-orange-600 shadow-lg dark:from-orange-500 dark:to-orange-700">
            <span class="text-3xl font-bold text-white">5</span>
          </div>
          <h3 class="mb-2 text-lg font-bold text-neutral-800 dark:text-neutral-200">
            Delivery & Support
          </h3>
          <p class="text-sm leading-relaxed text-neutral-600 dark:text-neutral-400">
            On-site delivery and dedicated after-sales support
          </p>
        </div>
      </div>
    </div>
  </section>

  {/* Testimonials from customers */}
  <!-- <section class="mx-auto max-w-[85rem] px-4 py-10 sm:px-6 lg:px-8 lg:py-14 2xl:max-w-full" id="testimonials">
    <div class="mb-10 text-center">
      <h2 class="text-balance text-2xl font-bold text-neutral-800 dark:text-neutral-200 sm:text-3xl lg:text-4xl">
