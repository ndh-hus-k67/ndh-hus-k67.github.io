      ))}
    </div>
  </section> -->

  {/* Quality Commitment */}
  <section class="mx-auto max-w-[85rem] px-4 py-10 sm:px-6 lg:px-8 lg:py-14 2xl:max-w-full">
    <div class="rounded-2xl bg-gradient-to-br from-orange-50 to-orange-100 p-8 dark:from-neutral-800 dark:to-neutral-900 md:p-12">
      <div class="text-center">
        <h2 class="mb-6 text-balance text-2xl font-bold text-neutral-800 dark:text-neutral-200 sm:text-3xl lg:text-4xl">
          HAHUTECH's Commitment
        </h2>
      </div>
      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-4">
        <div class="flex flex-col items-center text-center">
          <div class="mb-4 flex h-20 w-20 items-center justify-center rounded-full bg-white shadow-md dark:bg-neutral-800">
            <svg class="h-10 w-10 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
