---
// Import necessary components
import MainLayout from "@/layouts/MainLayout.astro";
import MainSection from "@components/ui/blocks/MainSection.astro";
import LeftSection from "@components/ui/blocks/LeftSection.astro";
import RightSection from "@components/ui/blocks/RightSection.astro";
import FeaturesStats from "@components/sections/features/FeaturesStats.astro";
import FAQ from "@components/sections/misc/FAQ.astro";
import ClientsSection from "@components/sections/landing/ClientsSection.astro";

// Import necessary images
import blueprints from "@images/quy-trinh-san-xuat-bulong.avif";
import personWorking from "@images/gia-cong-kim-loai.avif";
import beforeAfter from "@images/cong-ty-gia-cong-kim-loai-co-khi.avif";
import constructionWorkers from "@images/construction-workers.avif";
import aerialView from "@images/aerial-view.avif";
import usingTools from "@images/quy-trinh-gia-cong-kim-loai-tam.avif";
import progressBuilding from "@images/progress-building.avif";
import underConstruction from "@images/under-construction.avif";
import { SITE } from "@data/constants";
import {
  generateBreadcrumbSchema,
  generateGraphSchema,
} from "@/utils/schemas";

interface Article {
  isRightSection: boolean;
  title: string;
  subTitle: string;
  btnExists?: boolean;
  btnTitle?: string;
  btnURL?: string;
  single?: boolean;
  img?: any;
  imgAlt?: string;
  imgOne?: any;
  imgOneAlt?: string;
  imgTwo?: any;
  imgTwoAlt?: string;
}

// Testimonials from real customers
const testimonials = [
  {
    content: "HAHUTECH is a reliable supplier of aluminum profile accessories for our production lines. Product quality is consistent, delivery is fast, and pricing is competitive. Their support team is responsive and technically strong.",
    company: "Minh Phat Mechanical Co., Ltd.",
    industry: "Mechanical Manufacturing"
  },
  {
    content: "Custom manufacturing for aluminum profile accessories perfectly fits our needs. Products are delivered according to technical drawings and always on schedule. This is a reliable partner for our large projects.",
    company: "Saigon Shipbuilding Factory",
    industry: "Shipbuilding Industry"
  },
  {
    content: "Rich inventory, convenient ordering system, fast on-site delivery. Especially appreciate the 24h emergency delivery service, helping us avoid production disruptions.",
    company: "Automotive Industry Joint Stock Company",
    industry: "Automotive Manufacturing & Assembly"
  },
  {
    content: "Stable product quality, complete documentation, and fast VAT invoice support. Their consultants help us choose the right ball slides, latch slides, and profile accessories for each application.",
    company: "POSCO Vietnam Steel Factory",
    industry: "Steel Production"
  },
  {
    content: "Long-term cooperation with HAHUTECH, we are very satisfied with product quality and customer care service. Reasonable prices, flexible payment policy, well meeting business needs.",
    company: "Nagakawa Electronics Group",
    industry: "Electronics Manufacturing"
  },
  {
    content: "VMI service helps us optimize material inventory management, reduce frozen capital. HAHUTECH is always proactive in monitoring and replenishing materials promptly, helping production continue without interruption.",
    company: "Honda Vietnam Factory",
    industry: "Motorcycle Manufacturing"
  }
];

// Frequently Asked Questions
const faqs = {
  subTitle: "Answers to common questions about products and services",
  faqs: [
    {
      question: "What aluminum profile accessories does HAHUTECH supply?",
      answer: "We supply industrial aluminum profile accessories such as ball slides (truot bi), latch slides (truot lay), anti-rotation hidden brackets, boat sliders, T-nuts, profile connectors, hinges, and related assembly components. Materials include carbon steel, stainless steel (304, 316), alloy steel, and engineering plastics depending on application requirements."
    },
    {
      question: "What is the delivery time and shipping coverage?",
      answer: "For stock items: 24-48h for Ho Chi Minh City, Hanoi, Da Nang metro areas and 3-5 days for other provinces. For custom-made items: 7-15 days depending on quantity and complexity. We ship nationwide and support export."
    },
    {
      question: "Does HAHUTECH manufacture accessories according to custom drawings?",
      answer: "Yes. We manufacture aluminum profile accessories and assembly components based on customer 2D/3D drawings. We support both standardized and custom designs for pilot builds and mass production, with strict dimensional and quality controls."
    },
    {
      question: "How to order and make payment?",
      answer: "You can order via: (1) Phone/Zalo: contact sales directly, (2) Email: send product list, (3) Website: order online 24/7. We accept bank transfer, cash, credit payment (for regular customers with contracts). Full VAT invoice provided."
    },
    {
      question: "What is the warranty and return policy?",
      answer: "Defective products due to manufacturer are 100% exchangeable within 7 days. For custom-made goods, we commit to compensation if products do not match agreed technical drawings. All shipments have quality inspection sheets and origin certificates."
    },
    {
      question: "Is technical consulting support available?",
      answer: "Yes. Our engineering team provides free consultation on selecting the right ball slides, latch slides, profile connectors, materials, and surface treatments for your specific application. We also support drawing review and design optimization to reduce production costs."
    }
  ]
};

// Trusted partners
const partners = [
  {
    icon: `<svg class="h-auto w-16 text-neutral-600 dark:text-neutral-400" viewBox="0 0 100 40" xmlns="http://www.w3.org/2000/svg"><text x="5" y="25" font-size="14" font-weight="bold" fill="currentColor">VINFAST</text></svg>`,
    name: "VinFast",
    href: "#"
  },
  {
    icon: `<svg class="h-auto w-16 text-neutral-600 dark:text-neutral-400" viewBox="0 0 100 40" xmlns="http://www.w3.org/2000/svg"><text x="5" y="25" font-size="14" font-weight="bold" fill="currentColor">HONDA</text></svg>`,
    name: "Honda",
    href: "#"
  },
  {
    icon: `<svg class="h-auto w-16 text-neutral-600 dark:text-neutral-400" viewBox="0 0 100 40" xmlns="http://www.w3.org/2000/svg"><text x="5" y="25" font-size="14" font-weight="bold" fill="currentColor">THACO</text></svg>`,
    name: "Thaco",
    href: "#"
  },
  {
    icon: `<svg class="h-auto w-16 text-neutral-600 dark:text-neutral-400" viewBox="0 0 100 40" xmlns="http://www.w3.org/2000/svg"><text x="5" y="25" font-size="14" font-weight="bold" fill="currentColor">POSCO</text></svg>`,
    name: "Posco",
    href: "#"
  }
];

const articles: Article[] = [
  {
    isRightSection: true,
    title: "Expert Product Consultation",
    subTitle:
      "HAHUTECH understands that choosing the right aluminum profile accessories for each machine system is critical. Our specialists provide detailed guidance on ball slides, latch slides, hidden brackets, connectors, materials, dimensions, and protective finishes to match technical requirements and operating environments.",
    single: false,
    imgOne: blueprints,
    imgOneAlt: "Specialized aluminum profile accessories for industrial applications",
    imgTwo: personWorking,
    imgTwoAlt: "High-quality aluminum profile accessories manufactured at HAHUTECH",
  },
  {
    isRightSection: false,
    title: "Custom Accessory Manufacturing",
    subTitle:
      "With modern production lines and experienced engineers, HAHUTECH manufactures aluminum profile accessories and custom assembly parts according to customer drawings. We handle everything from small batches to mass production, ensuring dimensional accuracy, fit consistency, and strict quality control for each item.",
    img: beforeAfter,
    imgAlt: "Modern machinery and skilled technicians at HAHUTECH",
    // Removed "Learn More" button props
  },
  {
    isRightSection: true,
    title: "Fast Supply & Distribution",
    subTitle:
      "HAHUTECH maintains a large inventory of aluminum profile accessories and mechanical components to support urgent production demands. Our optimized logistics help deliver within 24-48 hours in major cities and 3-5 days nationwide. Ordering is flexible (online, phone, email), with competitive pricing for bulk and recurring customers.",
    single: false,
    imgOne: constructionWorkers,
    imgOneAlt: "HAHUTECH team supporting fast fulfillment",
    imgTwo: aerialView,
    imgTwoAlt: "Industrial projects using quality aluminum profile accessories supplied by HAHUTECH",
  },
  {
    isRightSection: false,
    title: "Quality Inspection & Certification",
    subTitle:
      "Every shipment is thoroughly inspected for dimensions, hardness, tensile strength, and protective coatings before release. We provide complete documentation on request, including certificates of quality (CO), certificates of origin (C/O), material test reports, and traceability records. Products comply with international standards (e.g., ISO 898-1, ASTM) and our quality management follows ISO 9001:2015.",
    img: usingTools,
    imgAlt:
      "Modern CNC machining and quality inspection at HAHUTECH",
  },
  {
    isRightSection: true,
    title: "End-to-End Solutions for Enterprises",
    subTitle:
      "HAHUTECH delivers comprehensive aluminum profile accessory supply solutions for manufacturers and assembly businesses in automation, electronics, machinery, and mechanical engineering. We support long-term supply contracts with flexible terms, VMI (Vendor Managed Inventory), and cost optimization consulting. With stable capacity and a diverse catalog, we help keep your production running smoothly.",
    single: false,
    imgOne: progressBuilding,
    imgOneAlt: "Large-scale projects supported by reliable aluminum profile accessory supply",
    imgTwo: underConstruction,
    imgTwoAlt: "Ongoing industrial installation with quality aluminum profile accessories",
    // Removed "Read more" button props
  },
];

const pageTitle: string = `Services | ${SITE.title}`;
const metaDescription =
  "HAHUTECH provides end-to-end solutions for industrial aluminum profile accessories, including ball slides, latch slides, technical consulting, custom manufacturing, quality control, and fast nationwide distribution.";
const ogTitle = `Aluminum Profile Accessories Services | ${SITE.title}`;

const aboutUrl = new URL("/en/about-us/", SITE.url).href;

const aboutPageNode = {
  "@type": "AboutPage",
  "@id": aboutUrl,
  url: aboutUrl,
  name: `Aluminum Profile Accessories Services | ${SITE.title}`,
  description: metaDescription,
  isPartOf: {
    "@id": `${SITE.url}/#website`,
  },
  inLanguage: "en-US",
};

const breadcrumbSchema = generateBreadcrumbSchema([
  { position: 1, name: "Home", item: SITE.url },
  { position: 2, name: "About us", item: aboutUrl },
]);

const structuredData = generateGraphSchema([
  aboutPageNode,
  breadcrumbSchema,
]);
---

<MainLayout
  title={pageTitle}
  lang="en"
  customDescription={metaDescription}
  customOgTitle={ogTitle}
  structuredData={structuredData}
>
  {/* MainSection is the introductory section of the page, it also contains a CTA button */}
  <MainSection
    title="A Trusted Partner for Aluminum Profile Accessories"
    subTitle="HAHUTECH supplies and manufactures high-quality industrial aluminum profile accessories, with strong expertise in ball slides and latch slides. With years of experience and a commitment to quality, we deliver end-to-end solutions from technical consultation and custom manufacturing to fast distribution."
    btnExists={false}
  />
  {/* RightSection and LeftSection contain details about various services along with pertinent imagery.
  They alternate for variety in design.
  The 'btnExists' property is used to toggle the display of a button in these sections.
  When btnExists={true}, a button is displayed.
  This can be used to link to more detailed information or related resources.
  RightSection can also conditionally render one or two images based on the 'single' property.
  If 'single' is true, it displays one image, otherwise it displays two.
  */}
  {
    articles.map((article) => {
      return article.isRightSection ? (
        <RightSection
          title={article.title}
          subTitle={article.subTitle}
          single={article.single}
          imgOne={article.imgOne}
          imgOneAlt={article.imgOneAlt}
          imgTwo={article.imgTwo}
          imgTwoAlt={article.imgTwoAlt}
          btnExists={article.btnExists}
          btnTitle={article.btnTitle}
          btnURL={article.btnURL}
        />
      ) : (
        <LeftSection
          title={article.title}
          subTitle={article.subTitle}
          img={article.img}
          imgAlt={article.imgAlt}
          btnExists={article.btnExists}
          btnTitle={article.btnTitle}
          btnURL={article.btnURL}
        />
      );
    })
  }
