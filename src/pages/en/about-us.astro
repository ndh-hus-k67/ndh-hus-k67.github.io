      },
      {
        stat: "500+",
        description: "trusted enterprises",
      },
      {
        stat: "24-48h",
        description: "fast delivery time",
      },
    ]}
  /> -->

  {/* 5-Step Work Process */}
  <section class="mx-auto max-w-[85rem] px-4 py-10 sm:px-6 lg:px-8 lg:py-14 2xl:max-w-full">
