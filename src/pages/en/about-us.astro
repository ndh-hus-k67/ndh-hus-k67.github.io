      {/* Connection line between steps - only shown on large screens */}
      <div class="absolute top-8 left-0 right-0 hidden h-0.5 bg-gradient-to-r from-orange-200 via-orange-400 to-orange-200 dark:from-orange-800 dark:via-orange-600 dark:to-orange-800 lg:block" style="width: 85%; margin: 0 auto;"></div>

      <div class="relative z-10 grid gap-8 sm:grid-cols-2 lg:grid-cols-5">
        <div class="flex flex-col items-center text-center">
          <div class="mb-4 flex h-20 w-20 items-center justify-center rounded-full bg-gradient-to-br from-orange-400 to-orange-600 shadow-lg dark:from-orange-500 dark:to-orange-700">
            <span class="text-3xl font-bold text-white">1</span>
          </div>
          <h3 class="mb-2 text-lg font-bold text-neutral-800 dark:text-neutral-200">
            Receive Request
          </h3>
          <p class="text-sm leading-relaxed text-neutral-600 dark:text-neutral-400">
            Contact via hotline, email or website with detailed information
          </p>
        </div>

        <div class="flex flex-col items-center text-center">
          <div class="mb-4 flex h-20 w-20 items-center justify-center rounded-full bg-gradient-to-br from-orange-400 to-orange-600 shadow-lg dark:from-orange-500 dark:to-orange-700">
            <span class="text-3xl font-bold text-white">2</span>
          </div>
