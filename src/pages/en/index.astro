---
// Import the necessary components
import MainLayout from "@/layouts/MainLayout.astro";
import HeroSection from "@components/sections/landing/HeroSection.astro";
import HeroSectionAlt from "@components/sections/landing/HeroSectionAlt.astro";
import ClientsSection from "@components/sections/landing/ClientsSection.astro";
import FeaturesGeneral from "@components/sections/features/FeaturesGeneral.astro";
import FeaturesNavs from "@components/sections/features/FeaturesNavs.astro";
import TestimonialsSection from "@components/sections/testimonials/TestimonialsSection.astro";
import PricingSection from "@components/sections/pricing/PricingSection.astro";
import FAQ from "@components/sections/misc/FAQ.astro";
import AnnouncementBanner from "@components/ui/banners/AnnouncementBanner.astro";
import ProductCategoriesSection from "@components/sections/landing/ProductCategoriesSection.astro";
import heroImage from "@images/hero-image.avif";
import faqs from "@data/en/faqs.json";
import features from "@data/en/features.json";
import pricing from "@data/en/pricing.json";
import construction from "@images/construction-image.avif";
import tools from "@/images/phu-kien-nhom-dinh-hinh-chat-luong-cao.avif";
import dashboard from "@images/dashboard-image.avif";
import bulongImage from "@images/bu-long-category.avif";
import ocvitImage from "@images/oc-vit-category.avif";
import tantugiuImage from "@images/tan-tu-giu-category.avif";
import tantrutugiuImage from "@images/tan-tru-tu-giu-category.avif";
import trurentugiuImage from "@images/tru-ren-tu-giu-category.avif";
import senxichImage from "@/images/products/sen-xich/xich-chot-rong.avif";
import phukiennhomImage from "@/images/products/phu-kien-nhom/con-truot-thuyen.avif";
import banleImage from "@/images/products/ban-le/ban-le-la.avif";
import { partnersData } from "@/data_files/constants";
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
import { getImage } from "astro:assets";

// Get all products to count by category (prefer EN, fallback to VN)
const fetchProductsByLang = async (lang: "en" | "vn") =>
  getCollection("products", ({ id }) => {
    const normalizedId = id.replace(/\\/g, "/");
    return normalizedId.includes(`${lang}/`) || id.includes(`${lang}\\`);
  });

const allProductsEn: CollectionEntry<"products">[] = await fetchProductsByLang("en");
const allProductsVn: CollectionEntry<"products">[] = await fetchProductsByLang("vn");
const allProducts = allProductsEn.length ? allProductsEn : allProductsVn;

// Define product categories
const productCategories = [
  {
    slug: "bolts",
    name: "Bolts",
    image: bulongImage,
    imageAlt: "Collection of high-quality bolts",
    count: allProducts.filter(p => {
      const categorySlug = typeof p.data.category === 'string' ? p.data.category : p.data.category?.slug;
      return categorySlug === "bu-long";
    }).length
  },
  {
    slug: "screws",
    name: "Screws",
    image: ocvitImage,
    imageAlt: "Various screw types",
    count: allProducts.filter(p => {
      const categorySlug = typeof p.data.category === 'string' ? p.data.category : p.data.category?.slug;
      return categorySlug === "oc-vit";
    }).length
  },
  {
    slug: "self-clinching-nuts",
    name: "Self-clinching nuts",
    image: tantugiuImage,
    imageAlt: "High-quality self-clinching nuts",
    count: allProducts.filter(p => {
      const categorySlug = typeof p.data.category === 'string' ? p.data.category : p.data.category?.slug;
      return categorySlug === "tan-tu-giu";
    }).length
  },
  {
    slug: "self-clinching-standoffs",
    name: "Self-clinching studs",
    image: tantrutugiuImage,
    imageAlt: "High-quality self-clinching studs",
    count: allProducts.filter(p => {
      const categorySlug = typeof p.data.category === 'string' ? p.data.category : p.data.category?.slug;
      return categorySlug === "tan-tru-tu-giu";
    }).length
  },
  {
    slug: "self-clinching-studs",
    name: "Threaded inserts",
    image: trurentugiuImage,
    imageAlt: "Threaded inserts",
    count: allProducts.filter(p => {
      const categorySlug = typeof p.data.category === 'string' ? p.data.category : p.data.category?.slug;
      return categorySlug === "tru-ren-tu-giu";
    }).length
  },
  {
    slug: "chains",
    name: "Chains & sprockets",
    image: senxichImage,
    imageAlt: "Industrial chains and sprockets",
    count: allProducts.filter((p) => {
      const categorySlug =
        typeof p.data.category === "string" ? p.data.category : p.data.category?.slug;
      return categorySlug === "sen-xich";
    }).length,
  },
  {
    slug: "aluminum-profile-accessories",
    name: "Aluminum profile accessories",
    image: phukiennhomImage,
    imageAlt: "Aluminum profile accessories",
    count: allProducts.filter((p) => {
      const categorySlug =
        typeof p.data.category === "string" ? p.data.category : p.data.category?.slug;
      return categorySlug === "phu-kien-nhom-dinh-hinh";
    }).length,
  },
  {
    slug: "hinges",
    name: "Hinges",
    image: banleImage,
    imageAlt: "High-quality industrial hinges",
    count: allProducts.filter((p) => {
      const categorySlug =
        typeof p.data.category === "string" ? p.data.category : p.data.category?.slug;
      return categorySlug === "ban-le";
    }).length,
  },
];

const avatarSrcs: Array<string> = [
  "https://images.unsplash.com/photo-1568602471122-7832951cc4c5?ixlib=rb-4.0.3&ixid=MnwxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8&auto=format&fit=facearea&facepad=2&w=300&h=300&q=80",
  "https://images.unsplash.com/photo-1531927557220-a9e23c1e4794?ixlib=rb-4.0.3&ixid=MnwxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8&auto=format&fit=facearea&facepad=2&w=300&h=300&q=80",
  "https://images.unsplash.com/photo-1541101767792-f9b2b1c4f127?ixlib=rb-4.0.3&ixid=MnwxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8&&auto=format&fit=facearea&facepad=3&w=300&h=300&q=80",
  "https://images.unsplash.com/photo-1492562080023-ab3db95bfbce?ixlib=rb-4.0.3&ixid=MnwxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8&auto=format&fit=facearea&facepad=2&w=300&h=300&q=80",
];

// Preload the LCP hero image (must match HeroSection widths/sizes)
const HERO_WIDTHS = [640, 960, 1280] as const;
const HERO_SIZES = "(min-width: 1024px) 640px, 100vw";

const heroCandidates = await Promise.all(
  HERO_WIDTHS.map((width) =>
    getImage({
      src: heroImage,
      width,
      format: "avif",
    }),
  ),
);

const heroSrcset = heroCandidates
  .map((img, i) => `${img.src} ${HERO_WIDTHS[i]}w`)
  .join(", ");

const heroPreloadHref = heroCandidates[1]?.src ?? heroCandidates[0]?.src;
---

<MainLayout lang="en">
  <Fragment slot="head">
    {heroPreloadHref && (
      <link
        rel="preload"
        as="image"
        href={heroPreloadHref}
        imagesrcset={heroSrcset}
        imagesizes={HERO_SIZES}
        type="image/avif"
      />
    )}
  </Fragment>
  <!-- <AnnouncementBanner
    btnId="dismiss-button"
    btnTitle="Explore ScrewFast on GitHub"
    url="https://github.com/mearashadowfax/ScrewFast"
  /> -->

  <HeroSection
    title="High-Quality Bolts & Fasteners Solutions from <span class='text-yellow-500 dark:text-yellow-400'>HAHUTECH</span>"
    subTitle="Specialized in trading and manufacturing high-quality bolts, screws, and nuts for all industrial and construction needs."
    primaryBtn="About Us"
    primaryBtnURL="/en/about-us"
    secondaryBtn="Contact Sales Team"
    secondaryBtnURL="/en/contact"
    withReview={true}
    avatars={avatarSrcs}
    rating="<span class='font-bold'>4.8</span> / 5"
    starCount={4}
    reviews="From Over <span class='font-bold'>12.8k</span> Reviews"
    src={heroImage}
    alt="High-quality bolts and fasteners products from HAHUTECH"
  />

  <!-- <ClientsSection
    title="Trusted by Industry Leaders"
    subTitle="Experience the reliability chosen by industry giants."
    partners={partnersData}
  /> -->

  <ProductCategoriesSection
    title="Explore Product Categories"
    subTitle="HAHUTECH offers a wide range of high-quality bolts, screws, and accessories for all industrial and construction needs."
    categories={productCategories}
    lang="en"
  />

  <FeaturesGeneral
    title="Meeting Industry Demands"
    subTitle="At HAHUTECH, we specialize in supplying and manufacturing high-quality bolts, screws, and nuts. With years of experience and modern technology, we are committed to providing optimal solutions for all industrial and construction projects."
    features={features}
  />

  <FeaturesNavs
    title=`<span class="text-yellow-500 dark:text-yellow-400">HAHUTECH</span>'s bolts and fasteners solutions perfectly meet all your industrial and construction needs.`
    tabs={[
      {
        heading: "High-Quality Manufacturing",
        content:
          "Manufacturing bolts and fasteners with international quality standards. HAHUTECH uses modern technology and strict production processes to ensure the highest durability and precision for each product.",
        svg: "tools",
        src: tools,
        alt: "High-precision, high-quality fabrication of aluminum profile accessories.",
        first: true,
      },
      {
        heading: "Diverse Product Range",
        content:
          "Supplying a wide variety of bolts, screws, and nuts in various sizes and strength grades. HAHUTECH maintains a rich inventory to quickly meet all requirements from small projects to large constructions.",
        svg: "dashboard",
        src: dashboard,
        alt: "Diverse inventory of bolts and fasteners products",
        second: true,
      },
      {
        heading: "Professional Services",
        content:
          "In-depth technical consultation and dedicated customer support. HAHUTECH's team is always ready to advise on the right product selection and provide optimal solutions for your specific project needs.",
        svg: "house",
        src: construction,
        alt: "Professional technical consulting and support services",
      },
    ]}
  />

  <!-- <TestimonialsSection
    title="Trusted Partner for Your Projects"
    subTitle="At HAHUTECH, we are committed to providing high-quality products and fast delivery. Experience professional bolts and fasteners trading services."
    testimonials={[
      {
        content:
          "HAHUTECH has provided us with high-quality bolts and fasteners at reasonable prices. Products meet standards, on-time delivery, and very dedicated support services. We are extremely satisfied with this partnership!",
        author: "Nguyen Van An",
        role: "Technical Director | Vietnam Construction Company",
        avatarSrc: "",
      },
    ]}
    statistics={[
      {
        count: "500+",
        description:
          "trusted customers — from small workshops to large construction corporations",
      },
      {
        count: "50+",
        description:
          "types of bolts and fasteners in various sizes and strength grades",
      },
      {
        count: "99%",
        description:
          "products meet international quality standards confirmed by customers",
      },
      {
        count: "24h",
        description:
          "fast delivery within city limits for in-stock orders",
      },
    ]}
  /> -->

  <!-- <PricingSection pricing={pricing} /> -->

<div id="faq">
  <FAQ title="Frequently<br />asked questions" faqs={faqs} />
</div>

</MainLayout>
