---
import MainLayout from "@/layouts/MainLayout.astro";
import { Image } from "astro:assets";
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
import type { ImageMetadata } from "astro";
import { SITE } from "@data/constants";
import { resolveLocalImageOrFallback } from "@/utils/resolveLocalImage";

export async function getStaticPaths() {
  const productEntries = await getCollection("products", ({ id, data }) => {
    const categorySlug = typeof data.category === 'string' ? data.category : data.category?.slug;
    const normalizedId = id.replace(/\\/g, "/");
    return (normalizedId.includes("en/") || id.includes("en\\")) && categorySlug === "tan-tru-tu-giu";
  });

  return productEntries.map((product) => {
    const slug = product.data.slug || product.id.split('/').pop()?.replace('.md', '');

    return {
      params: { slug: slug || '' },
      props: { product },
    };
  });
}

const { product } = Astro.props;

const productSlug = product.data.slug || product.id?.split("/").pop()?.replace(".md", "") || "";

const imgMainResolved = await resolveLocalImageOrFallback(
  product.data.main.imgMain,
  "@/images/product-default.avif"
);

const blueprintFirstResolved = product.data.blueprints?.first
  ? await resolveLocalImageOrFallback(
      product.data.blueprints.first,
      "@/images/blueprint-1.avif"
    )
  : undefined;

const pageTitle: string = product.data.seo?.title || `${product.data.title} | Self-Clinching Standoffs | ${SITE.title}`;
const metaDescription = product.data.seo?.description || product.data.description;
const ogTitle = `${product.data.title} | Self-clinching standoffs | ${SITE.title}`;

const productCollection: CollectionEntry<"products">[] = await getCollection("products", ({ id, data }) => {
  const categorySlug = typeof data.category === "string" ? data.category : data.category?.slug;
  const normalizedId = id.replace(/\\/g, "/");
  return (normalizedId.includes("en/") || id.includes("en\\")) && categorySlug === "tan-tru-tu-giu";
});

function shuffleArray<T>(arr: T[]): T[] {
  for (let i = arr.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [arr[i], arr[j]] = [arr[j], arr[i]];
  }
  return arr;
}

const relatedProducts: CollectionEntry<"products">[] = shuffleArray(
  productCollection.filter((p) => {
    const slug = p.data.slug || p.id.split("/").pop()?.replace(".md", "");
    return slug !== (product.data.slug || product.id.split("/").pop()?.replace(".md", ""));
  })
).slice(0, 4);

type RelatedResolved = { entry: CollectionEntry<"products">; img: ImageMetadata; slug: string };

const relatedResolved: RelatedResolved[] = await Promise.all(
  relatedProducts.map(async (entry) => {
    const slug = (entry.data.slug ?? entry.id.split("/").pop()?.replace(".md", "")) ?? "";
    const img: ImageMetadata = await resolveLocalImageOrFallback(entry.data.main?.imgMain, "@/images/product-default.avif");
    return { entry, img, slug };
  })
);
---

<MainLayout
  title={pageTitle}
  customDescription={metaDescription}
  customOgTitle={ogTitle}
  customOgImage={imgMainResolved}
  ogType="product"
  structuredData={{
    "@context": "https://schema.org",
    "@type": "Product",
    "@id": `${SITE.url}/en/self-clinching-standoffs/${productSlug}`,
    name: product.data.title,
    description: metaDescription,
    image: imgMainResolved ? [`${SITE.url}${imgMainResolved.src}`] : undefined,
    category: "Self-clinching standoffs",
    brand: {
      "@type": "Brand",
      name: "HAHUTECH",
    },
    inLanguage: "en-US",
  }}
>
  <!-- Breadcrumb -->
  <section class="mx-auto max-w-[85rem] px-4 py-6 sm:px-6 lg:px-8">
    <nav class="text-sm" aria-label="Breadcrumb">
      <ol class="flex items-center space-x-2">
        <li><a href="/en" class="text-neutral-600 hover:text-orange-500 dark:text-neutral-400">Home</a></li>
        <li><span class="text-neutral-400">›</span></li>
        <li><a href="/en/self-clinching-standoffs" class="text-neutral-600 hover:text-orange-500 dark:text-neutral-400">Self-clinching standoffs</a></li>
        <li><span class="text-neutral-400">›</span></li>
        <li class="font-medium text-orange-500 dark:text-orange-400">{product.data.title}</li>
      </ol>
    </nav>
  </section>

  <!-- Main Content -->
  <section class="mx-auto max-w-[85rem] px-4 pb-16 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 gap-8 lg:grid-cols-3">
      <!-- Main Content Area -->
      <div class="lg:col-span-2">
        <!-- Title -->
        <h1 class="mb-4 text-3xl font-bold text-neutral-900 dark:text-neutral-100 uppercase">
          {product.data.title}
        </h1>
        <p class="mb-8 text-neutral-600 dark:text-neutral-400">
          {product.data.description}
        </p>

        <!-- Description -->
        {
          product.data.main?.content && (
            <div class="mb-8 rounded-lg border border-neutral-200 bg-orange-50 p-6 dark:border-neutral-700 dark:bg-orange-950/20">
              <h2 class="mb-3 text-lg font-semibold text-neutral-900 dark:text-neutral-100">Product Description</h2>
              <div class="leading-relaxed text-neutral-700 dark:text-neutral-300" set:html={product.data.main.content} />
            </div>
          )
        }

        <!-- Blueprint -->
        {
          blueprintFirstResolved && (
            <div class="mb-8">
              <h2 class="mb-4 text-xl font-semibold text-neutral-900 dark:text-neutral-100">
                Technical Drawing
              </h2>
              <div class="rounded-lg border border-neutral-200 bg-white p-6 shadow-sm dark:border-neutral-700 dark:bg-neutral-900">
                <Image
                  src={blueprintFirstResolved}
                  class="mx-auto max-h-96 w-auto"
                  alt="Technical Drawing"
                  format={"avif"}
                />
              </div>
            </div>
          )
        }

        <!-- Specifications Table -->
        {
          product.data.tableData && product.data.tableData.length > 0 && (
            <div class="mb-8 space-y-6">
              <h2 class="mb-4 text-xl font-semibold text-neutral-900 dark:text-neutral-100">
                Technical Specifications
              </h2>
              {product.data.tableData.map((table) => (
                <div class="overflow-hidden rounded-lg border border-neutral-200 shadow-sm dark:border-neutral-700">
                  <div class="overflow-x-auto">
                    <table class="min-w-full">
                      <thead class="bg-orange-400">
                        <tr>
                          {table.feature?.map((header) => (
                            <th class="px-6 py-3 text-left text-sm font-semibold text-white">
                              {header}
                            </th>
                          ))}
                        </tr>
                      </thead>
                      <tbody class="divide-y divide-neutral-200 bg-white dark:divide-neutral-700 dark:bg-neutral-900">
                        {table.description.map((rowData) => (
                          <tr class="hover:bg-orange-50 dark:hover:bg-orange-950/20">
                            {rowData.map((cellValue, idx) => (
                              <td class={`px-6 py-3 text-sm ${idx === 0 ? 'font-medium text-neutral-900 dark:text-neutral-100' : 'text-neutral-700 dark:text-neutral-300'}`}>
                                {cellValue}
                              </td>
                            ))}
                          </tr>
                        ))}
                      </tbody>
                    </table>
                  </div>
                </div>
              ))}
            </div>
          )
        }
      </div>

      <!-- Sidebar -->
      <div class="lg:col-span-1">
        <div class="space-y-6 lg:sticky lg:top-4">
          <!-- Product Image -->
          {
            imgMainResolved && (
              <div class="rounded-lg border border-neutral-200 bg-white p-4 shadow-sm dark:border-neutral-700 dark:bg-neutral-900">
                <Image
                  src={imgMainResolved}
                  class="w-full rounded"
                  alt={product.data.main?.imgAlt || product.data.title}
                  format={"avif"}
                  loading="eager"
                  fetchpriority="high"
                  decoding="async"
                  widths={[360, 480, 640]}
                  sizes="(min-width: 1024px) 360px, 100vw"
                />
              </div>
            )
          }

          <!-- Contact Box -->
          <div class="rounded-lg border border-neutral-200 bg-white p-6 shadow-sm dark:border-neutral-700 dark:bg-neutral-800">
            <h3 class="mb-2 text-lg font-semibold text-neutral-900 dark:text-neutral-100">
              Need Support?
            </h3>
            <p class="mb-5 text-sm text-neutral-600 dark:text-neutral-400">
              Contact us for consultation and detailed quotation.
            </p>
            <div class="space-y-3">
              <a 
                href="tel:0347741638" 
                class="flex items-center justify-center gap-2 w-full rounded-lg bg-orange-500 px-4 py-2.5 text-center text-sm font-semibold text-white hover:bg-orange-600 transition"
              >
                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
                </svg>
                Contact Us
              </a>
              <a 
                href="/en/contact" 
                class="block w-full rounded-lg border border-neutral-300 bg-neutral-50 px-4 py-2.5 text-center text-sm font-medium text-neutral-700 hover:bg-neutral-100 transition dark:border-neutral-600 dark:bg-neutral-700 dark:text-neutral-200 dark:hover:bg-neutral-600"
              >
                Contact Info
              </a>
             
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
    {
      relatedResolved && relatedResolved.length > 0 && (
        <section class="mx-auto max-w-[85rem] px-4 pb-16 sm:px-6 lg:px-8">
          <h2 class="mb-6 text-2xl font-semibold text-neutral-900 dark:text-neutral-100">Related products</h2>
          <div class="grid grid-cols-2 gap-4 md:grid-cols-4">
            {relatedResolved.map(({ entry, img, slug }) => (
              <a href={`/en/self-clinching-standoffs/${slug}`} class="block rounded-lg border border-neutral-200 bg-white p-3 text-center hover:shadow-sm dark:border-neutral-700 dark:bg-neutral-900">
                {img && (
                  <Image src={img} alt={entry.data.main?.imgAlt || entry.data.title} class="mx-auto mb-3 h-28 w-auto object-contain" format={"avif"} />
                )}
                <div class="text-sm font-medium text-neutral-900 dark:text-neutral-100">{entry.data.title}</div>
              </a>
            ))}
          </div>
        </section>
      )
    }
</MainLayout>
