---
// Import the necessary components
import MainLayout from "@/layouts/MainLayout.astro";
import ContactSection from "@components/sections/misc/ContactSection.astro";
import { SITE } from "@data/constants";

const pageTitle: string = `Liên hệ | ${SITE.title}`;
const metaDescription =
  "Liên hệ HAHUTECH để được tư vấn và báo giá bu lông, ốc vít, vật tư công nghiệp chất lượng cao. Đội ngũ chuyên nghiệp sẵn sàng hỗ trợ 24/7. Gọi ngay để nhận ưu đãi!";
const ogTitle = "Liên hệ HAHUTECH - Tư vấn bu lông ốc vít chất lượng cao";
---

<MainLayout
  title={pageTitle}
  customDescription={metaDescription}
  customOgTitle={ogTitle}
  structuredData={{
    "@context": "https://schema.org",
    "@type": "ContactPage",
    "@id": `${SITE.url}/lien-he`,
    url: `${SITE.url}/lien-he`,
    name: `Liên hệ | ${SITE.title}`,
    description: metaDescription,
    isPartOf: {
      "@type": "WebSite",
      url: SITE.url,
      name: SITE.title,
      description: SITE.description,
    },
    inLanguage: "vi-VN",
  }}
>
  <ContactSection />
</MainLayout>
