---
import MainLayout from "@/layouts/MainLayout.astro";
import { SITE } from "@data/constants";
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
import { getCategoryTitleVN, getSubcategoryTitleVN } from "@/utils/productTitles";
import {
  buildFacetOptions,
  getProductMaterialsFromTags,
  getProductSizesFromTags,
} from "@/utils/productFacets";

const allProducts: CollectionEntry<"products">[] = (
  await getCollection("products", ({ id }) => id.startsWith("vn/"))
).sort((a, b) => a.data.main.id - b.data.main.id);

const categoryOrder = ["bu-long", "oc-vit", "san-pham-khac"] as const;

const categories = categoryOrder.map((slug) => {
  const products = allProducts.filter((p) => p.data.category === slug);
  const subcats = Array.from(
    products.reduce((acc, p) => {
      const k = p.data.subcategory;
      acc.set(k, (acc.get(k) ?? 0) + 1);
      return acc;
    }, new Map<string, number>())
  )
    .map(([subSlug, count]) => ({
      slug: subSlug,
      name: getSubcategoryTitleVN(subSlug),
      count,
    }))
    .sort((a, b) => a.name.localeCompare(b.name, "vi", { sensitivity: "base" }));

  return {
    slug,
    name: getCategoryTitleVN(slug),
    count: products.length,
    subcategories: subcats,
  };
});

const subcategoryOptions = categories.flatMap((cat) =>
  cat.subcategories.map((sub) => ({
    category: cat.slug,
    slug: sub.slug,
    name: sub.name,
  }))
);

const materialOptions = buildFacetOptions(allProducts.flatMap(getProductMaterialsFromTags));
const sizeOptions = buildFacetOptions(allProducts.flatMap(getProductSizesFromTags));

const title = `Tìm sản phẩm | ${SITE.title}`;
const description =
  "Tìm kiếm sản phẩm theo tên gọi, vật liệu và kích thước. Lọc theo danh mục để thu hẹp kết quả.";
---

<MainLayout
  title={title}
  customDescription={description}
  structuredData={{
    "@context": "https://schema.org",
    "@type": "SearchResultsPage",
    name: "Tìm sản phẩm",
    description,
    inLanguage: "vn",
  }}
>
  <div class="mx-auto max-w-[85rem] px-4 py-10 sm:px-6 lg:px-8 lg:py-14 2xl:max-w-full">
    <div class="mb-8">
      <h1 class="text-balance text-3xl font-bold tracking-tight text-neutral-800 md:text-4xl dark:text-neutral-200">
        Tìm sản phẩm
      </h1>
      <p class="mt-3 max-w-3xl text-pretty text-neutral-600 dark:text-neutral-400">
        Lọc theo tên gọi, vật liệu và kích thước (giống kiểu trang “Bộ lọc tìm kiếm”).
      </p>
    </div>

    <div class="flex flex-col gap-8 lg:flex-row lg:gap-12">
      <!-- Sidebar -->
      <aside class="lg:w-96 lg:shrink-0">
        <div class="sticky top-24 space-y-6">
          <div class="rounded-2xl border border-neutral-200 bg-white p-6 shadow-sm dark:border-neutral-700 dark:bg-neutral-800">
            <h2 class="mb-4 text-lg font-semibold uppercase tracking-wide text-neutral-800 dark:text-neutral-200">
              Bộ lọc tìm kiếm
            </h2>

            <div class="space-y-4">
              <div>
                <label for="filter-q" class="mb-1 block text-sm font-medium text-neutral-700 dark:text-neutral-300">
                  Từ khóa
                </label>
                <input
                  id="filter-q"
                  type="search"
                  placeholder="Nhập tên sản phẩm…"
                  class="w-full rounded-lg border border-neutral-300 bg-white px-3 py-2 text-sm text-neutral-800 outline-none focus:border-orange-400 focus:ring-2 focus:ring-orange-200 dark:border-neutral-600 dark:bg-neutral-900 dark:text-neutral-200 dark:focus:ring-orange-900"
                />
              </div>

              <div>
                <label for="filter-category" class="mb-1 block text-sm font-medium text-neutral-700 dark:text-neutral-300">
                  Danh mục
                </label>
                <select
                  id="filter-category"
                  class="w-full rounded-lg border border-neutral-300 bg-white px-3 py-2 text-sm text-neutral-800 outline-none focus:border-orange-400 focus:ring-2 focus:ring-orange-200 dark:border-neutral-600 dark:bg-neutral-900 dark:text-neutral-200 dark:focus:ring-orange-900"
                >
                  <option value="">Tất cả</option>
                  {categories.map((c) => (
                    <option value={c.slug}>{c.name}</option>
                  ))}
                </select>
              </div>

              <div>
                <label for="filter-subcategory" class="mb-1 block text-sm font-medium text-neutral-700 dark:text-neutral-300">
                  Nhóm sản phẩm
                </label>
                <select
                  id="filter-subcategory"
                  class="w-full rounded-lg border border-neutral-300 bg-white px-3 py-2 text-sm text-neutral-800 outline-none focus:border-orange-400 focus:ring-2 focus:ring-orange-200 dark:border-neutral-600 dark:bg-neutral-900 dark:text-neutral-200 dark:focus:ring-orange-900"
                >
                  <option value="">Tất cả</option>
                  {subcategoryOptions.map((s) => (
                    <option value={s.slug} data-category={s.category}>
                      {s.name}
                    </option>
                  ))}
                </select>
              </div>

              <div>
                <label for="filter-material" class="mb-1 block text-sm font-medium text-neutral-700 dark:text-neutral-300">
                  Vật liệu
                </label>
                <select
                  id="filter-material"
                  class="w-full rounded-lg border border-neutral-300 bg-white px-3 py-2 text-sm text-neutral-800 outline-none focus:border-orange-400 focus:ring-2 focus:ring-orange-200 dark:border-neutral-600 dark:bg-neutral-900 dark:text-neutral-200 dark:focus:ring-orange-900"
                >
                  <option value="">Tất cả</option>
                  {materialOptions.map((m) => (
                    <option value={m}>{m}</option>
                  ))}
                </select>
              </div>

              <div>
                <label for="filter-size" class="mb-1 block text-sm font-medium text-neutral-700 dark:text-neutral-300">
                  Kích thước
                </label>
                <select
                  id="filter-size"
                  class="w-full rounded-lg border border-neutral-300 bg-white px-3 py-2 text-sm text-neutral-800 outline-none focus:border-orange-400 focus:ring-2 focus:ring-orange-200 dark:border-neutral-600 dark:bg-neutral-900 dark:text-neutral-200 dark:focus:ring-orange-900"
                >
                  <option value="">Tất cả</option>
                  {sizeOptions.map((s) => (
                    <option value={s}>{s}</option>
                  ))}
                </select>
              </div>

              <div class="flex items-center justify-between gap-3 pt-2">
                <button
                  id="filter-reset"
                  type="button"
                  class="inline-flex items-center rounded-lg border border-neutral-300 bg-white px-3 py-2 text-sm font-medium text-neutral-700 hover:bg-neutral-50 dark:border-neutral-600 dark:bg-neutral-900 dark:text-neutral-200 dark:hover:bg-neutral-800"
                >
                  Xóa lọc
                </button>
                <p class="text-sm text-neutral-600 dark:text-neutral-400">
                  <span id="filter-count" class="font-semibold text-neutral-800 dark:text-neutral-200">
                    {allProducts.length}
                  </span>
                  / {allProducts.length}
                </p>
              </div>
            </div>
          </div>

          <div class="rounded-2xl border border-neutral-200 bg-white p-6 shadow-sm dark:border-neutral-700 dark:bg-neutral-800">
            <h2 class="mb-4 text-lg font-semibold uppercase tracking-wide text-neutral-800 dark:text-neutral-200">
              Danh mục sản phẩm
            </h2>
            <div class="space-y-2">
              {categories.map((c) => (
                <a
                  href={`?category=${c.slug}`}
                  class="flex items-center justify-between rounded-lg px-3 py-2 text-sm text-neutral-700 hover:bg-neutral-50 dark:text-neutral-200 dark:hover:bg-neutral-700"
                >
                  <span class="font-medium">{c.name}</span>
                  <span class="text-xs text-neutral-500 dark:text-neutral-400">{c.count}</span>
                </a>
              ))}
            </div>
          </div>
        </div>
      </aside>

      <!-- Results -->
      <main class="min-w-0 flex-1">
        <div class="mb-4 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
          <p class="text-sm text-neutral-600 dark:text-neutral-400">
            Kết quả tìm kiếm: (<span id="results-count" class="font-semibold text-neutral-800 dark:text-neutral-200">{allProducts.length}</span>
            sản phẩm)
          </p>

          <div class="flex items-center gap-3">
            <label for="filter-sort" class="text-sm font-medium text-neutral-700 dark:text-neutral-300">Sắp xếp</label>
            <select
              id="filter-sort"
              class="rounded-lg border border-neutral-300 bg-white px-3 py-2 text-sm text-neutral-800 outline-none focus:border-orange-400 focus:ring-2 focus:ring-orange-200 dark:border-neutral-600 dark:bg-neutral-900 dark:text-neutral-200 dark:focus:ring-orange-900"
            >
              <option value="id-asc">Mặc định</option>
              <option value="id-desc">Mới nhất</option>
              <option value="name-asc">Tên A → Z</option>
              <option value="name-desc">Tên Z → A</option>
            </select>
          </div>
        </div>

        <div id="results-empty" class="hidden rounded-2xl border border-neutral-200 bg-white p-10 text-center text-neutral-600 dark:border-neutral-700 dark:bg-neutral-800 dark:text-neutral-400">
          Không tìm thấy sản phẩm phù hợp.
        </div>

        <div id="results-grid" class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {allProducts.map((product) => {
            const slug = product.id.split("/").pop()?.replace(".md", "") ?? "";
            const url = `/products/${product.data.category}/${product.data.subcategory}/${slug}`;
            const imgSrc =
              typeof product.data.main.imgCard === "string"
                ? product.data.main.imgCard
                : product.data.main.imgCard.src;

            const materials = getProductMaterialsFromTags(product);
            const sizes = getProductSizesFromTags(product);

            return (
              <a
                href={url}
                data-astro-prefetch
                data-product-item
                data-id={String(product.data.main.id)}
                data-title={product.data.title}
                data-category={product.data.category}
                data-subcategory={product.data.subcategory}
                data-materials={materials.join("|")}
                data-sizes={sizes.join("|")}
                class="group relative flex h-64 items-end overflow-hidden rounded-xl shadow-md outline-hidden ring-zinc-500 transition-shadow hover:shadow-xl focus-visible:ring-3 dark:ring-zinc-200 dark:focus:outline-hidden"
              >
                <img
                  src={imgSrc}
                  alt={product.data.main.imgAlt}
                  class="absolute inset-0 h-full w-full object-cover object-center transition duration-[600ms] ease-[cubic-bezier(0.45,0,0.55,1)] group-hover:scale-110"
                />
                <div class="pointer-events-none absolute inset-0 bg-gradient-to-t from-neutral-900 via-neutral-900/40 to-transparent" />
                <div class="relative w-full p-4">
                  <div class="text-base font-bold text-neutral-50 md:text-lg">
                    {product.data.title}
                  </div>
                  <div class="mt-2 flex flex-wrap gap-2 text-xs text-neutral-100/90">
                    {materials.slice(0, 2).map((m) => (
                      <span class="rounded-full bg-white/10 px-2 py-1">{m}</span>
                    ))}
                    {sizes.slice(0, 2).map((s) => (
                      <span class="rounded-full bg-white/10 px-2 py-1">{s}</span>
                    ))}
                  </div>
                </div>
              </a>
            );
          })}
        </div>

        <nav class="mt-8 flex items-center justify-center" aria-label="Pagination">
          <div id="results-pagination" class="flex flex-wrap items-center gap-2"></div>
        </nav>
      </main>
    </div>
  </div>
</MainLayout>

<script is:inline>
  (function () {
    const els = {
      q: document.getElementById("filter-q"),
      category: document.getElementById("filter-category"),
      subcategory: document.getElementById("filter-subcategory"),
      material: document.getElementById("filter-material"),
      size: document.getElementById("filter-size"),
      sort: document.getElementById("filter-sort"),
      reset: document.getElementById("filter-reset"),
      count: document.getElementById("filter-count"),
      resultsCount: document.getElementById("results-count"),
      empty: document.getElementById("results-empty"),
      pagination: document.getElementById("results-pagination"),
    };

    const itemEls = Array.from(document.querySelectorAll("[data-product-item]"));

    if (
      !els.q ||
      !els.category ||
      !els.subcategory ||
      !els.material ||
      !els.size ||
      !els.sort ||
      !els.reset ||
      !els.count ||
      !els.resultsCount ||
      !els.empty ||
      !els.pagination
    ) {
      return;
    }

    const PER_PAGE = 24;

    const strip = (s) =>
      (s || "")
        .normalize("NFD")
        .replace(/[\u0300-\u036f]/g, "")
        .toLowerCase()
        .trim();

    const splitTokens = (value) =>
      (value || "")
        .split("|")
        .map((x) => strip(x))
        .filter(Boolean);

    const cache = itemEls.map((el) => {
      return {
        el,
        id: Number(el.dataset.id || 0),
        title: strip(el.dataset.title),
        category: strip(el.dataset.category),
        subcategory: strip(el.dataset.subcategory),
        materials: splitTokens(el.dataset.materials),
        sizes: splitTokens(el.dataset.sizes),
      };
    });

    function readParams() {
      const url = new URL(window.location.href);
      return {
        q: url.searchParams.get("q") || "",
        category: url.searchParams.get("category") || "",
        subcategory: url.searchParams.get("subcategory") || "",
        material: url.searchParams.get("material") || "",
        size: url.searchParams.get("size") || "",
        sort: url.searchParams.get("sort") || "id-asc",
        page: Number(url.searchParams.get("page") || "1") || 1,
      };
    }

    function writeParams(next) {
      const url = new URL(window.location.href);
      const set = (k, v) => {
        if (!v) url.searchParams.delete(k);
        else url.searchParams.set(k, String(v));
      };

      set("q", next.q);
      set("category", next.category);
      set("subcategory", next.subcategory);
      set("material", next.material);
      set("size", next.size);
      set("sort", next.sort && next.sort !== "id-asc" ? next.sort : "");
      set("page", next.page && next.page !== 1 ? next.page : "");

      window.history.replaceState({}, "", url);
    }

    function syncSubcategoryOptions() {
      const cat = strip(els.category.value);
      const opts = Array.from(els.subcategory.querySelectorAll("option[data-category]"));
      opts.forEach((o) => {
        const ok = !cat || strip(o.getAttribute("data-category")) === cat;
        o.hidden = !ok;
      });

      // If current subcategory doesn't belong to selected category, clear it.
      const selected = els.subcategory.value;
      if (selected) {
        const selOpt = els.subcategory.querySelector(`option[value='${CSS.escape(selected)}']`);
        if (selOpt && selOpt.hidden) els.subcategory.value = "";
      }
    }

    function sortItems(items, sortKey) {
      if (sortKey === "id-desc") return items.slice().sort((a, b) => b.id - a.id);
      if (sortKey === "name-asc")
        return items.slice().sort((a, b) => (a.title || "").localeCompare(b.title || "", "vi", { numeric: true }));
      if (sortKey === "name-desc")
        return items.slice().sort((a, b) => (b.title || "").localeCompare(a.title || "", "vi", { numeric: true }));
      return items.slice().sort((a, b) => a.id - b.id);
    }

    function renderPagination(current, totalPages, onGo) {
      els.pagination.innerHTML = "";
      if (totalPages <= 1) return;

      const mkBtn = (label, page, disabled, active) => {
        const btn = document.createElement("button");
        btn.type = "button";
        btn.textContent = label;
        btn.disabled = disabled;
        btn.className =
          "min-w-9 rounded-lg border px-3 py-2 text-sm " +
          (active
            ? "border-orange-400 bg-orange-50 text-orange-700 dark:bg-orange-950 dark:text-orange-300"
            : "border-neutral-300 bg-white text-neutral-700 hover:bg-neutral-50 dark:border-neutral-600 dark:bg-neutral-900 dark:text-neutral-200 dark:hover:bg-neutral-800");
        btn.addEventListener("click", () => onGo(page));
        return btn;
      };

      const mkDots = () => {
        const span = document.createElement("span");
        span.textContent = "…";
        span.className = "px-2 text-sm text-neutral-500 dark:text-neutral-400";
        return span;
      };

      els.pagination.appendChild(mkBtn("‹", Math.max(1, current - 1), current === 1, false));

      const windowSize = 2;
      const pages = new Set([1, totalPages]);
      for (let p = Math.max(1, current - windowSize); p <= Math.min(totalPages, current + windowSize); p++) pages.add(p);

      const ordered = Array.from(pages).sort((a, b) => a - b);
      let prev = 0;
      for (const p of ordered) {
        if (prev && p - prev > 1) els.pagination.appendChild(mkDots());
        els.pagination.appendChild(mkBtn(String(p), p, false, p === current));
        prev = p;
      }

      els.pagination.appendChild(mkBtn("›", Math.min(totalPages, current + 1), current === totalPages, false));
    }

    function applyFilters(pushUrl = true) {
      syncSubcategoryOptions();

      const q = strip(els.q.value);
      const category = strip(els.category.value);
      const subcategory = strip(els.subcategory.value);
      const material = strip(els.material.value);
      const size = strip(els.size.value);
      const sortKey = els.sort.value || "id-asc";

      const filtered = cache.filter((it) => {
        const okQ = !q || (it.title && it.title.includes(q));
        const okCat = !category || it.category === category;
        const okSub = !subcategory || it.subcategory === subcategory;
        const okMat = !material || it.materials.includes(material);
        const okSize = !size || it.sizes.includes(size);
        return okQ && okCat && okSub && okMat && okSize;
      });

      const sorted = sortItems(filtered, sortKey);

      const total = sorted.length;
      const totalPages = Math.max(1, Math.ceil(total / PER_PAGE));

      const url = new URL(window.location.href);
      const pageFromUrl = Number(url.searchParams.get("page") || "1") || 1;
      const currentPage = Math.min(Math.max(1, pageFromUrl), totalPages);

      const start = (currentPage - 1) * PER_PAGE;
      const end = start + PER_PAGE;
      const visibleSet = new Set(sorted.slice(start, end).map((x) => x.el));

      for (const it of cache) {
        it.el.hidden = !visibleSet.has(it.el);
      }

      els.count.textContent = String(total);
      els.resultsCount.textContent = String(total);
      els.empty.classList.toggle("hidden", total !== 0);

      renderPagination(currentPage, totalPages, (nextPage) => {
        const next = {
          q: els.q.value,
          category: els.category.value,
          subcategory: els.subcategory.value,
          material: els.material.value,
          size: els.size.value,
          sort: els.sort.value,
          page: nextPage,
        };
        writeParams(next);
        applyFilters(false);
        window.scrollTo({ top: 0, behavior: "smooth" });
      });

      if (pushUrl) {
        writeParams({
          q: els.q.value,
          category: els.category.value,
          subcategory: els.subcategory.value,
          material: els.material.value,
          size: els.size.value,
          sort: els.sort.value,
          page: currentPage,
        });
      }
    }

    function initFromUrl() {
      const p = readParams();
      els.q.value = p.q;
      els.category.value = p.category;
      syncSubcategoryOptions();
      els.subcategory.value = p.subcategory;
      els.material.value = p.material;
      els.size.value = p.size;
      els.sort.value = p.sort;

      // Normalize URL once (avoid invalid page index)
      writeParams({
        q: p.q,
        category: p.category,
        subcategory: p.subcategory,
        material: p.material,
        size: p.size,
        sort: p.sort,
        page: p.page,
      });

      applyFilters(false);
    }

    els.q.addEventListener("input", () => {
      const p = readParams();
      writeParams({ ...p, q: els.q.value, page: 1 });
      applyFilters(false);
    });

    els.category.addEventListener("change", () => {
      const p = readParams();
      writeParams({ ...p, category: els.category.value, subcategory: "", page: 1 });
      els.subcategory.value = "";
      applyFilters(false);
    });

    els.subcategory.addEventListener("change", () => {
      const p = readParams();
      writeParams({ ...p, subcategory: els.subcategory.value, page: 1 });
      applyFilters(false);
    });

    els.material.addEventListener("change", () => {
      const p = readParams();
      writeParams({ ...p, material: els.material.value, page: 1 });
      applyFilters(false);
    });

    els.size.addEventListener("change", () => {
      const p = readParams();
      writeParams({ ...p, size: els.size.value, page: 1 });
      applyFilters(false);
    });

    els.sort.addEventListener("change", () => {
      const p = readParams();
      writeParams({ ...p, sort: els.sort.value, page: 1 });
      applyFilters(false);
    });

    els.reset.addEventListener("click", () => {
      els.q.value = "";
      els.category.value = "";
      els.subcategory.value = "";
      els.material.value = "";
      els.size.value = "";
      els.sort.value = "id-asc";

      writeParams({
        q: "",
        category: "",
        subcategory: "",
        material: "",
        size: "",
        sort: "id-asc",
        page: 1,
      });

      applyFilters(false);
      els.q.focus();
    });

    initFromUrl();
  })();
</script>
